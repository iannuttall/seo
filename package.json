{
  "name": "seo",
  "version": "0.1.0",
  "description": "SEO Skills CLI and MCP for finding technical problems, ranking fixes with search data, and running reports locally.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Ian Nuttall",
  "homepage": "https://seoskills.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iannuttall/seo.git"
  },
  "bugs": {
    "url": "https://github.com/iannuttall/seo/issues"
  },
  "funding": "https://github.com/iannuttall/seo",
  "keywords": [
    "seo",
    "search-console",
    "google-analytics",
    "crawler",
    "cli",
    "mcp"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "seo": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "evals",
    "PRIVACY.md",
    "SECURITY.md",
    "TERMS.md",
    "TRADEMARKS.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "auth:inject-shared-client": "node scripts/inject-shared-oauth-client.mjs",
    "build": "turbo run build && pnpm run build:package",
    "build:package": "tsdown --config tsdown.config.ts",
    "clean": "turbo run clean && rm -rf dist",
    "dev": "turbo run dev",
    "lint": "biome check . && node scripts/check-emdashes.mjs && node scripts/check-report-parity.mjs && pnpm run skills:validate && turbo run lint",
    "lint:fix": "biome check . --write",
    "loc:audit": "node scripts/loc-audit.mjs",
    "pack:check": "pnpm pack --dry-run",
    "prepack": "pnpm run skills:validate && pnpm run build:package && node --test scripts/package.test.mjs",
    "security:audit": "pnpm audit --audit-level low",
    "security:check": "pnpm run security:audit && pnpm run security:secrets",
    "security:secrets": "node scripts/security-secrets.mjs",
    "skills:validate": "node scripts/validate-skills.mjs",
    "test": "turbo run test && pnpm run build:package && node --test scripts/package.test.mjs && pnpm run skills:validate",
    "test:package-install": "pnpm run build:package && node --test scripts/installed-package.test.mjs",
    "typecheck": "turbo run typecheck"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@napi-rs/keyring": "^1.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.20.1",
    "better-sqlite3": "^12.11.1",
    "citty": "^0.2.2",
    "cli-table3": "^0.6.5",
    "consola": "^3.4.2",
    "debug": "^4.4.3",
    "defuddle": "^0.19.1",
    "jsonc-parser": "^3.3.1",
    "lighthouse": "13.4.0",
    "linkedom": "^0.18.13",
    "open": "^11.0.0",
    "p-queue": "^9.3.1",
    "p-retry": "^8.0.0",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright-core": "1.61.1",
    "proper-lockfile": "^4.1.2",
    "robots-parser": "^3.0.1",
    "schema-dts": "^2.0.0",
    "undici": "^8.7.0",
    "update-notifier": "^7.3.1",
    "user-agents": "2.1.117",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@changesets/cli": "^2.31.0",
    "tsdown": "^0.22.4",
    "turbo": "^2.10.4",
    "typescript": "^6.0.3"
  }
}
