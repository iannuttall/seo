---
interface Props {
  title?: string
}

const { title } = Astro.props
---

<svg
  class="logo-mark"
  viewBox="0 0 32 32"
  role={title ? 'img' : undefined}
  aria-label={title}
  aria-hidden={title ? undefined : 'true'}
  xmlns="http://www.w3.org/2000/svg"
>
  <path d="M4 4h24v6H10v3h18v15H4v-6h18v-3H4z" fill="currentColor"></path>
  <path class="logo-accent" d="M4 13h6v6H4z"></path>
</svg>
