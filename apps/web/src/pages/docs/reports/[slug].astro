---
import DottedCard from '@/components/DottedCard.astro'
import PageHeader from '@/components/PageHeader.astro'
import PagerNav from '@/components/PagerNav.astro'
import CopyCode from '@/components/docs/CopyCode.astro'
import SiteCrawlReportGuide from '@/components/reports/SiteCrawlReportGuide.astro'
import {
  editorialReports,
  legacyReportAliases,
  reportSlugs,
  reports,
  reportsById,
} from '@/content/reports'
import { resolveReportGuide } from '@/content/reports/guides'
import { humanReportCommand } from '@/content/reports/commands'
import {
  categoryLabels,
  describeCommand,
  reportCommand,
  reportMetaDescription,
  reportPageTitle,
  reportPath,
} from '@/content/reports/helpers'
import { reportSources } from '@/content/reports/sources'
import type { ReportEditorial } from '@/content/reports/types'
import BaseLayout from '@/layouts/BaseLayout.astro'

export function getStaticPaths() {
  return [
    ...reports.map((report) => ({
      params: {
        slug:
          reportSlugs[report.id as keyof typeof reportSlugs] ?? report.id,
      },
      props: { report },
    })),
    ...Object.entries(reportSlugs).map(([id]) => ({
      params: { slug: id },
      props: { redirectTo: reportPath(id) },
    })),
    ...Object.entries(legacyReportAliases).map(([slug, target]) => ({
      params: { slug },
      props: {
        redirectTo: target.startsWith('/') ? target : reportPath(target),
      },
    })),
  ]
}

type Props = {
  report?: ReportEditorial
  redirectTo?: string
}

const { report, redirectTo } = Astro.props

if (redirectTo) {
  return Astro.redirect(redirectTo, 301)
}

if (!report) {
  return Astro.rewrite('/404')
}

const relatedReports = report.related
  .map((id) => reportsById.get(id))
  .filter((item): item is ReportEditorial => item !== undefined)
const sources = report.sources.map((key) => reportSources[key])
const guide = resolveReportGuide(report)
const relatedGuides = relatedReports.map(resolveReportGuide)
const description = reportMetaDescription(report, guide.seo)
const pageTitle = reportPageTitle(report, guide.seo, guide.name)
const reportIndex = editorialReports.findIndex(({ id }) => id === report.id)
const previousReport =
  reportIndex > 0 ? editorialReports[reportIndex - 1] : undefined
const nextReport =
  reportIndex >= 0 && reportIndex < editorialReports.length - 1
    ? editorialReports[reportIndex + 1]
    : undefined
const previousGuide = previousReport
  ? resolveReportGuide(previousReport)
  : undefined
const nextGuide = nextReport ? resolveReportGuide(nextReport) : undefined
const isSiteCrawlPilot = report.id === 'site-crawl'
const hasSeparateChecks = guide.checks !== report.methodology
const humanCommand = humanReportCommand(report.id)
const commands = [
  ...(humanCommand
    ? [
        {
          label: 'Run it from the CLI',
          value: humanCommand.command,
        },
      ]
    : []),
  {
    label: 'Check the agent input schema',
    value: describeCommand(report),
  },
  {
    label: 'Run it from an agent or script',
    value: reportCommand(report),
  },
]
const parameterNames = Object.keys(report.exampleParams)
const commandFacts = [
  ['Report id', report.id],
  ['Execution', 'Local process'],
  ['Outputs', 'JSON and Markdown'],
  [
    'Example parameters',
    parameterNames.length > 0 ? parameterNames.join(', ') : 'No parameters',
  ],
  ['Agent discovery', `seo reports describe ${report.id} --json`],
  ['Interactive prompts', 'Human CLI commands only'],
]
const mcpDescribeInput = JSON.stringify({ id: report.id }, null, 2)
const mcpRunInput = JSON.stringify(
  { id: report.id, params: report.exampleParams },
  null,
  2,
)
const libraryExample = `import { executeReport } from 'seo/mcp'

const result = await executeReport(
  '${report.id}',
  ${JSON.stringify(report.exampleParams, null, 2)},
)

console.log(result)`
function alternativeReportName(id: string): string {
  const alternative = reportsById.get(id)
  return alternative ? resolveReportGuide(alternative).name : id
}
---

<BaseLayout
  title={pageTitle}
  description={description}
  canonicalPath={reportPath(report.id)}
>
  <main>
    <nav aria-label="Breadcrumb" class="mb-6 text-sm text-foreground-muted">
      <ol class="flex flex-wrap items-center gap-1.5">
        <li>
          <a
            class="underline decoration-border underline-offset-4 transition-colors hover:decoration-foreground"
            href="/"
          >
            Home
          </a>
        </li>
        <li aria-hidden="true" class="text-border">/</li>
        <li>
          <a
            class="underline decoration-border underline-offset-4 transition-colors hover:decoration-foreground"
            href="/docs"
          >
            Docs
          </a>
        </li>
        <li aria-hidden="true" class="text-border">/</li>
        <li>
          <a
            class="underline decoration-border underline-offset-4 transition-colors hover:decoration-foreground"
            href="/docs/reports"
          >
            Reports
          </a>
        </li>
        <li aria-hidden="true" class="text-border">/</li>
        <li class="text-foreground">{guide.name}</li>
      </ol>
    </nav>

    {
      isSiteCrawlPilot ? (
        <SiteCrawlReportGuide report={report} guide={guide} />
      ) : (
        <PageHeader
          title={guide.seo?.heading ?? guide.name}
          description={guide.lead}
          align="left"
        />
      )
    }

    {!isSiteCrawlPilot ? (
    <div class="docs-prose">
      <p>
        Run this report from the CLI, an MCP client, or application code. Every
        surface uses the same report definition and returns the same evidence.
        JSON is the source of truth; Markdown makes it readable without hiding
        dates, limits, warnings, or skipped work.
      </p>

      <h2 id="what-this-report-helps-you-decide">
        What this report helps you decide
      </h2>
      <p>{report.question}</p>
      <ul>
        {report.useWhen.map((item) => <li>{item}</li>)}
      </ul>

      <h2 id="command-facts">Command facts</h2>
      <div class="mt-4 font-mono">
        <DottedCard patternId={`facts-${report.id}`}>
          <div class="flex items-center justify-between gap-3 border-b-2 border-nav px-4 py-2 text-xs">
            <span>{report.id}</span>
            <span class="text-foreground-muted">{categoryLabels[report.category]}</span>
          </div>
          <dl class="divide-y divide-border text-sm">
            {
              commandFacts.map(([label, value]) => (
                <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1 px-4 py-2.5">
                  <dt class="shrink-0 font-sans">{label}</dt>
                  <dd class="min-w-0 text-xs text-foreground-muted">{value}</dd>
                </div>
              ))
            }
          </dl>
        </DottedCard>
      </div>

      <h2 id="when-this-report-is-not-the-right-tool">
        When this report is not the right tool
      </h2>
      <p>
        These cases need a different report, more evidence, or a human decision.
        Do not force this report to answer a question its data cannot support.
      </p>
      <ul>
        {
          guide.alternatives.map((alternative) => (
            <li>
              <strong>{alternative.when}</strong>{' '}
              {alternative.reportId ? (
                <>
                  <strong>Recommended report:</strong>{' '}
                  <a href={reportPath(alternative.reportId)}>
                    {alternativeReportName(alternative.reportId)}
                  </a>.{' '}
                </>
              ) : null}
              {alternative.doInstead}
            </li>
          ))
        }
      </ul>

      <h2 id="data-sources-and-inputs">Data sources and inputs</h2>
      <ul>
        {
          guide.inputs.map((input) => (
            <li>
              <strong>{input.label}</strong>
              {input.role ? `. ${input.role}` : null}
            </li>
          ))
        }
      </ul>

      <h2 id="what-this-report-checks">
        {hasSeparateChecks
          ? 'What this report checks'
          : 'What this report checks and how'}
      </h2>
      <ul>
        {guide.checks.map((item) => <li>{item}</li>)}
      </ul>
      {
        hasSeparateChecks ? (
          <>
            <h2 id="how-it-works">How it works</h2>
            <ul>
              {report.methodology.map((item) => <li>{item}</li>)}
            </ul>
          </>
        ) : null
      }
      <p>
        The JSON result keeps dates, thresholds, limits, skipped work, and
        source completeness beside the finding. Missing, partial, capped,
        filtered, and complete data remain different states.
      </p>

      <h2 id="run-the-report-from-the-cli">Run the report from the CLI</h2>
      <p>
        {humanCommand
          ? humanCommand.note
          : 'This report currently uses the shared report runner in the CLI.'}
        {' '}Agents and CI should inspect the live schema before their first run.
      </p>

      {
        commands.map(({ label, value }) => (
          <CopyCode label={label} value={value} />
        ))
      }

      <p>
        Project profiles can fill supported property and analytics inputs for
        the human-facing commands. The catalog form shown here is explicit by
        design, so agents and CI jobs do not prompt or guess.
      </p>

      <h2 id="how-an-mcp-agent-should-use-it">
        How an MCP agent should use it
      </h2>
      <p>
        Call <code>seo_describe_report</code> first so the agent sees when this
        report is useful and gets the current input schema. Then call
        <code>seo_run_report</code> with the validated parameters. Read the
        status, warnings, source limits, and skipped sections before acting on
        a finding.
      </p>
      <CopyCode label="Describe the report with MCP" value={mcpDescribeInput} />
      <CopyCode label="Run the report with MCP" value={mcpRunInput} />
      <p>
        Use a follow-up report returned by the result instead of guessing the
        next tool. The local MCP server and CLI use the same report definition
        and evidence. Their outer transport envelopes differ.
      </p>

      <h2 id="use-the-report-in-a-typescript-app">
        Use the report in a TypeScript app
      </h2>
      <p>
        Install <code>seo</code> as a project dependency, then call the same
        report catalog used by the CLI and MCP. <code>executeReport</code>
        rejects an unknown report id or invalid parameters. Provider and
        runtime failures come back as structured results with
        <code>isError</code> set.
      </p>
      <CopyCode label="Install the library" value="npm install seo" />
      <CopyCode label="Run this report from TypeScript" value={libraryExample} />
      <p>
        The <a href="/docs/typescript">TypeScript package guide</a> also covers
        direct core functions, schema discovery, and the difference between
        <code>executeReport</code> and <code>runReport</code>.
      </p>

      <h2 id="what-comes-back">What comes back and how to read it</h2>
      <ul>
        {guide.returns.map((item) => <li>{item}</li>)}
        {report.interpretation.map((item) => <li>{item}</li>)}
      </ul>
      <p>
        Start with <code>dataStatus</code>, source details, warnings, and
        caveats. Then inspect the observed evidence before derived findings or
        suggested actions.
      </p>

      <h2 id="what-this-report-cannot-tell-you">
        What this report cannot tell you
      </h2>
      <ul>
        {report.caveats.map((item) => <li>{item}</li>)}
      </ul>

      <h2 id="what-to-do-next">What to do next</h2>
      <ol class="mt-3 list-decimal space-y-1.5 pl-5 text-base/6">
        {report.nextSteps.map((item) => <li>{item}</li>)}
      </ol>

      <h2 id="related-reports">Related reports</h2>
      <ul>
        {
          relatedGuides.map((related) => (
            <li>
              <a href={reportPath(related.id)}>{related.name}</a>.{' '}
              {related.summary}
            </li>
          ))
        }
      </ul>

      {
        sources.length ? (
          <>
            <h2 id="sources-behind-the-guidance">
              Sources behind the guidance
            </h2>
            <p>
              These primary sources define the provider data or search controls
              used in the interpretation above.
            </p>
            <ul>
              {sources.map((source) => (
                <li>
                  <a href={source.url} target="_blank" rel="noreferrer">
                    {source.label}
                  </a>
                </li>
              ))}
            </ul>
          </>
        ) : null
      }

      <p>
        <a href="/docs/reports">Browse all reports</a> in{' '}
        {categoryLabels[report.category]}.
      </p>
    </div>
    ) : null}

    {
      previousReport || nextReport ? (
        <PagerNav
          ariaLabel="Report docs"
          previous={
            previousReport && previousGuide
              ? { label: previousGuide.name, href: reportPath(previousReport.id) }
              : undefined
          }
          next={
            nextReport && nextGuide
              ? { label: nextGuide.name, href: reportPath(nextReport.id) }
              : undefined
          }
        />
      ) : null
    }
  </main>
</BaseLayout>
