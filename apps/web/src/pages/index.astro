---
import InstallPicker from '@/components/InstallPicker.astro'
import Logo from '@/components/Logo.astro'
import SiteLayout from '@/layouts/SiteLayout.astro'
import { productFacts } from '@/lib/facts'
import { site } from '@/lib/site'
---

<SiteLayout>
  <div class="shell home-shell">
    <section class="home-hero">
      <Logo title="SEO Skills CLI" />
      <h1>
        <span class="scramble-text" data-scramble="TECHNICAL SEO SKILLS" aria-hidden="true">TECHNICAL SEO SKILLS</span>
        <span class="visually-hidden">Technical SEO skills</span>
        <em>for AI agents.</em>
      </h1>
      <p class="lead">
        Crawl sites, connect real search data, and turn technical evidence into
        prioritised fixes. One local CLI for agents, developers, and CI.
      </p>
      <InstallPicker />
      <p class="install-note">Open source / Apache-2.0 / Working data stays local</p>
      <div class="hero-actions">
        <a class="button" href="/docs/getting-started">Get started</a>
        <a class="button secondary" href={site.repository}>View on GitHub</a>
      </div>
    </section>

    <section class="home-section intro-section" aria-labelledby="what-it-does">
      <div class="home-intro">
        <h2 id="what-it-does">Give agents evidence, not SEO folklore.</h2>
        <p>
          SEO Skills combines live crawls with Search Console and GA4 data. It
          finds technical problems, shows the pages and queries they affect,
          and ranks the work so an agent can act without guessing.
        </p>
      </div>
      <ul class="feature-list">
        <li>
          <h3>Deterministic reports</h3>
          <p>Stable schemas, rule IDs, date ranges, and bounded evidence.</p>
        </li>
        <li>
          <h3>Real priorities</h3>
          <p>Fixes ranked by technical severity, affected URLs, and search value.</p>
        </li>
        <li>
          <h3>Agent-ready context</h3>
          <p>Compact JSON and Markdown that explain findings, caveats, and next steps.</p>
        </li>
        <li>
          <h3>Local by default</h3>
          <p>No hosted report backend, job queue, or account full of client data.</p>
        </li>
      </ul>
      <p class="scope-note">
        {productFacts.reports} discoverable reports / {productFacts.crawlerRules} crawler rules / {productFacts.skills} agent skills
      </p>
    </section>

    <section class="home-section report-section" aria-labelledby="show-working">
      <div class="home-intro">
        <h2 id="show-working">Reports that show their working.</h2>
        <p>
          Every recommendation stays connected to observed data. Sparse inputs
          become explicit caveats, not false certainty, and follow-up commands
          keep the next request small enough for an agent context window.
        </p>
      </div>
      <div class="report-demo" aria-label="Example SEO report output">
        <div class="report-demo-header">
          <span>seo report --project example</span>
          <span>local / read-only</span>
        </div>
        <div class="report-demo-body">
          <p><span class="report-status high">high</span><strong>17 valuable URLs are not indexable</strong></p>
          <p class="report-evidence">Search Console clicks: 8,421 / affected templates: 2 / source: crawl + GSC</p>
          <p class="report-action"><span>$</span> seo affected-urls --rule noindex_page --project example</p>
          <p><span class="report-status watch">watch</span><strong>CTR evidence is too sparse for a safe verdict</strong></p>
          <p class="report-evidence">Section skipped / reason retained in JSON / no zero-value substitution</p>
        </div>
      </div>
    </section>

    <section class="home-section local-section" aria-labelledby="local-data">
      <Logo />
      <h2 id="local-data">Your clients' data stays on the machine doing the work.</h2>
      <p>
        OAuth tokens, project profiles, caches, and saved reports remain local.
        Requests go to Google and the sites you choose to inspect. There is no
        SEO account, analytics tracker, or hosted report database in the middle.
      </p>
      <a href="/privacy">Read the privacy model</a>
    </section>

    <section class="home-section closing-section" aria-labelledby="use-anywhere">
      <h2 id="use-anywhere">One report engine. CLI, Node, skills, and MCP.</h2>
      <p>Start with the guided setup, or give an agent the exact report schema it needs.</p>
      <div class="hero-actions">
        <a class="button" href="/docs/reports">Explore the reports</a>
        <a class="button secondary" href="/docs/agents">Connect an agent</a>
      </div>
    </section>
  </div>
</SiteLayout>
