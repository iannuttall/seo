---
import PixelIcon from '@/components/icons/PixelIcon.astro'

type PagerLink = {
  label: string
  href: string
}

type Props = {
  ariaLabel: string
  previous?: PagerLink
  next?: PagerLink
}

const { ariaLabel, previous, next } = Astro.props
---

{/* translate-y-12 walks the blocks down over the framed page's py-12 bottom
    padding so they dock onto the footer's top border; their own bottom border
    is dropped so the footer rule completes the box. */}
<nav aria-label={ariaLabel} class="mt-16 grid translate-y-12 grid-cols-2 items-stretch gap-4">
  {
    previous ? (
      <a
        href={previous.href}
        class="group flex min-w-0 items-center gap-3 border-2 border-b-0 border-nav bg-background px-5 py-4 transition-colors hover:bg-foreground hover:text-background"
      >
        <PixelIcon name="arrow-left" class="size-4 shrink-0" />
        <span class="flex min-w-0 flex-col gap-0.5">
          <span class="text-xs text-foreground-muted transition-colors group-hover:text-background">Previous</span>
          <span class="truncate text-sm">{previous.label}</span>
        </span>
      </a>
    ) : (
      <span />
    )
  }
  {
    next ? (
      <a
        href={next.href}
        class="group flex min-w-0 items-center justify-end gap-3 border-2 border-b-0 border-nav bg-background px-5 py-4 text-right transition-colors hover:bg-foreground hover:text-background"
      >
        <span class="flex min-w-0 flex-col gap-0.5">
          <span class="text-xs text-foreground-muted transition-colors group-hover:text-background">Next</span>
          <span class="truncate text-sm">{next.label}</span>
        </span>
        <PixelIcon name="arrow-right" class="size-4 shrink-0" />
      </a>
    ) : (
      <span />
    )
  }
</nav>
