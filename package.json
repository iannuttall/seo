{
  "name": "seo",
  "version": "0.1.0",
  "description": "Local-first SEO reports, crawling, Google Search Console, GA4, CLI, and MCP tools.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Ian Nuttall",
  "homepage": "https://seoskills.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iannuttall/seo.git"
  },
  "bugs": {
    "url": "https://github.com/iannuttall/seo/issues"
  },
  "keywords": [
    "seo",
    "search-console",
    "google-analytics",
    "crawler",
    "cli",
    "mcp"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "seo": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "PRIVACY.md",
    "TERMS.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "auth:inject-shared-client": "node scripts/inject-shared-oauth-client.mjs",
    "build": "turbo run build && pnpm run build:package",
    "build:package": "tsup --config tsup.config.ts",
    "clean": "turbo run clean && rm -rf dist",
    "dev": "turbo run dev --parallel",
    "lint": "biome check . && node scripts/check-emdashes.mjs && node scripts/check-report-parity.mjs && turbo run lint",
    "lint:fix": "biome check . --write",
    "loc:audit": "node scripts/loc-audit.mjs",
    "pack:check": "pnpm pack --dry-run",
    "prepack": "pnpm run build:package && node --test scripts/package.test.mjs",
    "test": "turbo run test && pnpm run build:package && node --test scripts/package.test.mjs",
    "typecheck": "turbo run typecheck"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@googleapis/searchconsole": "^6.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@napi-rs/keyring": "^1.3.0",
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.2.0",
    "citty": "^0.2.2",
    "cli-table3": "^0.6.5",
    "consola": "^3.4.2",
    "debug": "^4.4.3",
    "defuddle": "^0.19.1",
    "env-paths": "^3.0.0",
    "google-auth-library": "^10.9.0",
    "jsonc-parser": "^3.3.1",
    "lighthouse": "13.4.0",
    "linkedom": "^0.18.13",
    "open": "^10.2.0",
    "p-queue": "^8.1.1",
    "p-retry": "^7.1.1",
    "picocolors": "^1.1.1",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "proper-lockfile": "^4.1.2",
    "robots-parser": "^3.0.1",
    "schema-dts": "^1.1.5",
    "undici": "^7.28.0",
    "update-notifier": "^7.3.1",
    "user-agents": "2.1.115",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@changesets/cli": "^2.31.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.3",
    "tsup": "^8.5.1",
    "turbo": "^2.10.4",
    "typescript": "^5.9.3"
  }
}
