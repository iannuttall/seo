---
import FeatureDemo from '@/components/FeatureDemo.astro'
import { productFacts } from '@/lib/facts'

const features = [
  {
    title: "Chat with your SEO data to find out what works and what doesn't.",
    description:
      'Ask why traffic dropped, which keywords deserve research, who competes in search, or what blocks a crawl. Your agent answers from first-party evidence and clearly labelled provider estimates.',
    demo: 'mcp',
  },
  {
    title: 'Use the CLI with Codex or Claude Code to ship SEO fixes fast.',
    description:
      'Run an audit in the terminal and let your coding agent trace each problem to the code. You get a reviewable fix without copying findings between tools.',
    demo: 'cli',
  },
  {
    title: 'Run a complete SEO audit and know what to fix next.',
    description: `Run ${productFacts.reports} reports across crawl health, content, search performance, keyword and competitor research, programmatic SEO, and AI visibility. Each result shows the evidence and limits behind the next action.`,
    demo: 'crawl',
  },
  {
    title: 'Make your site easier for AI search engines to understand and cite.',
    description:
      'Check whether AI crawlers can access your pages and understand what your site is about. Your agent can fix the gaps and draft an llms.txt from the pages you choose.',
    demo: 'ai',
  },
  {
    title: 'Build SEO checks into the tools and workflows your team already uses.',
    description:
      'Import the typed crawler and reports from the seo package. Add audits to CI, content pipelines, internal tools, or whatever you are already building.',
    demo: 'library',
  },
  {
    title: 'See which SEO fixes worked and where your effort should go next.',
    description:
      'Compare every release against saved crawl and search performance data. See what improved, what stayed flat, and which changes need more time before you call them a win.',
    demo: 'measure',
  },
] as const
---

<section class="border-b-2 border-nav">
  <div class="mx-auto w-full max-w-4xl px-8 md:px-12">
    <div class="grid border-x-2 border-nav sm:auto-rows-fr">
      {features.map((feature, index) => {
        const demoRight = index % 2 === 0

        return (
          <article class="grid grid-cols-1 border-b-2 border-nav last:border-b-0 sm:grid-cols-2">
            <div
              class:list={[
                'flex min-h-52 flex-col justify-center px-6 py-8 sm:px-8',
                demoRight && 'sm:border-r-2 sm:border-nav',
                !demoRight && 'sm:order-2',
              ]}
            >
              <h2 class="text-lg font-normal tracking-wide">{feature.title}</h2>
              <p class="mt-3 font-sans text-sm leading-6 text-foreground-muted">{feature.description}</p>
            </div>

            <div
              class:list={[
                'h-full border-t-2 border-nav sm:border-t-0',
                demoRight && 'sm:order-2',
                !demoRight && 'sm:border-r-2 sm:border-nav',
              ]}
            >
              <FeatureDemo demo={feature.demo} patternId={`feature-demo-${index}`} title={feature.title} />
            </div>
          </article>
        )
      })}
    </div>
  </div>
</section>
