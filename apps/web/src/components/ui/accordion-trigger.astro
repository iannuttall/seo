---
import type { HTMLAttributes } from "astro/types";
import PixelIcon from "@/components/icons/PixelIcon.astro";
import { cn } from "@/lib/utils";

type AccordionTriggerProps = HTMLAttributes<"button">;

const { class: className, ...props } = Astro.props as AccordionTriggerProps;
---
<h3 class="flex text-sm font-normal tracking-wide">
    <button
      data-accordion-trigger
      aria-expanded="false"
      class={cn(
        'group flex flex-1 cursor-pointer items-center justify-between gap-4 px-6 py-5 text-left text-sm outline-none',
        'transition-colors hover:bg-background-subtle',
        'focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-primary',
        className
      )}
      {...props}
    >
      <slot />
      <PixelIcon name="chevron-down-2" class="size-3.5 shrink-0 text-foreground transition-transform duration-200 group-aria-expanded:rotate-180" />
    </button>
  </h3>
