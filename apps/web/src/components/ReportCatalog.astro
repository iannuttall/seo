---
import NavCard from '@/components/NavCard.astro'
import { editorialReports } from '@/content/reports'
import { reportCollections } from '@/content/reports/collections'
import { resolveReportGuide } from '@/content/reports/guides'
import { reportPath } from '@/content/reports/helpers'

const catalogCollections = reportCollections.map((collection) => ({
  ...collection,
  reports: collection.reports.map(([id, label]) => {
    const report = editorialReports.find((item) => item.id === id)
    if (!report) throw new Error(`Missing report ${id} in docs catalog.`)
    return { report, label }
  }),
}))
---

<div class="mt-8 space-y-12">
  {
    catalogCollections.map((collection) => {
      return (
        <section>
          <header>
            <h2 class="text-lg font-normal leading-7 tracking-wide">{collection.title}</h2>
            <p class="mt-2 font-sans text-foreground-muted">
              {collection.introduction}
            </p>
          </header>

          <div class="mt-6 grid grid-cols-1 gap-x-8 gap-y-6 sm:auto-rows-fr sm:grid-cols-2">
            {collection.reports.map(({ report, label }) => {
              const guide = resolveReportGuide(report)
              return (
                <NavCard title={label} description={guide.summary} href={reportPath(report.id)}>
                  <span class="mt-auto font-mono text-xs text-foreground-faint">{report.id}</span>
                </NavCard>
              )
            })}
          </div>
        </section>
      )
    })
  }
</div>
