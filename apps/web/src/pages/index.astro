---
import InstallPicker from '@/components/InstallPicker.astro'
import Logo from '@/components/Logo.astro'
import SiteLayout from '@/layouts/SiteLayout.astro'
import { productFacts } from '@/lib/facts'
import { site } from '@/lib/site'
---

<SiteLayout>
  <div class="shell home-shell">
    <section class="home-hero">
      <Logo title="SEO Skills CLI" />
      <h1>Find the SEO work <em>worth doing.</em></h1>
      <p class="lead">
        Crawl your site, connect real search data, and get a clear list of what
        to fix first. The reports run locally and work just as well for people,
        agents, and CI.
      </p>
      <InstallPicker />
      <p class="install-note">Node 22+ / Apache-2.0 / Your working data stays local</p>
      <div class="hero-actions">
        <a class="button" href="/docs/getting-started">Start with the CLI</a>
        <a class="button secondary" href={site.repository}>Read the source</a>
      </div>
    </section>

    <ul class="metric-list" aria-label="Project facts">
      <li><strong>{productFacts.reports}</strong> discoverable reports</li>
      <li><strong>{productFacts.crawlerRules}</strong> crawler rules</li>
      <li><strong>{productFacts.skills}</strong> agent skills</li>
      <li><strong>0</strong> hosted report backends</li>
    </ul>

    <section class="home-section" aria-labelledby="normal-path">
      <div class="section-heading">
        <h2 id="normal-path">Get from setup to a useful report quickly</h2>
        <p>
          <code>seo start</code> handles Google sign-in, property selection,
          and a local project profile. Then <code>seo report</code> checks the
          evidence you have and points to the next useful report.
        </p>
      </div>
      <ol class="steps">
        <li>
          <h3>Connect your site</h3>
          <p>Follow a short prompt flow. You do not need to create config files or learn the command tree.</p>
        </li>
        <li>
          <h3>See what matters</h3>
          <p>Combine crawl evidence with read-only Search Console and GA4 data to rank the work.</p>
        </li>
        <li>
          <h3>Inspect the evidence</h3>
          <p>Open focused reports for the affected pages, queries, templates, and technical rules.</p>
        </li>
      </ol>
    </section>

    <section class="home-section" aria-labelledby="trust-reports">
      <div class="section-heading">
        <h2 id="trust-reports">Reports that show their working</h2>
        <p>
          Observations stay separate from interpretations. Every report exposes
          its date range, retained rows, source limits, skipped sections, and
          caveats. Missing data stays missing instead of becoming a false zero.
        </p>
      </div>
      <div class="surface-list">
        <div class="surface-row">
          <h3>Fixes tied to evidence</h3>
          <p>Priorities explain the affected URL or query, the observed signal, and why the action is worth reviewing.</p>
        </div>
        <div class="surface-row">
          <h3>Stable output for agents</h3>
          <p>JSON, Markdown, rule IDs, and bounded evidence make reports safe to pass into scripts and model context.</p>
        </div>
        <div class="surface-row">
          <h3>One core across every surface</h3>
          <p>The CLI, Node library, skills, and local MCP server run the same report implementations.</p>
        </div>
      </div>
    </section>

    <section class="home-section" aria-labelledby="local-data">
      <div class="local-note">
        <div>
          <h2 id="local-data">Keep the work on your machine</h2>
          <p>
            OAuth tokens, project profiles, caches, and saved reports stay with
            the machine running the command. Requests go to Google and the sites
            you choose to inspect. There is no SEO account or report database to maintain.
          </p>
        </div>
        <ul>
          <li>Read-only Google scopes</li>
          <li>Private local file permissions</li>
          <li>No project usage telemetry</li>
          <li>No background job queue</li>
        </ul>
      </div>
    </section>

    <section class="home-section closing-section" aria-labelledby="use-anywhere">
      <h2 id="use-anywhere">Use the same SEO evidence wherever the work happens.</h2>
      <div class="hero-actions">
        <a class="button" href="/docs/reports">Explore the reports</a>
        <a class="button secondary" href="/docs/agents">Connect an agent</a>
      </div>
    </section>
  </div>
</SiteLayout>
