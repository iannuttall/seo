---
interface Props {
  title?: string
}

const { title } = Astro.props
---

<svg
  class="logo-mark"
  viewBox="0 0 112 112"
  role={title ? 'img' : undefined}
  aria-label={title}
  aria-hidden={title ? undefined : 'true'}
  xmlns="http://www.w3.org/2000/svg"
>
  <rect class="logo-tile" width="112" height="112"></rect>
  <path class="logo-glyph" d="M10 10h92v24H48v10h54v58H10V78h54V68H10z"></path>
</svg>
