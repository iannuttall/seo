---
import { installCommands } from '@/lib/install'
import DottedCard from '@/components/DottedCard.astro'
import InlineCode from '@/components/InlineCode.astro'
import PixelIcon from '@/components/icons/PixelIcon.astro'

const { standalone = false } = Astro.props as { standalone?: boolean }
const install = installCommands[0]
---

<section class:list={[standalone && 'max-w-2xl']} data-install-picker>
  <div class="font-sans" data-agent-markdown="exclude">
    <DottedCard>
      <button
        type="button"
        class="group flex w-full cursor-pointer appearance-none items-center justify-between gap-3 bg-background p-6 pb-10 text-left transition-colors hover:bg-foreground hover:text-background focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        data-copy-install-command
        aria-label={`Copy ${install.command}`}
      >
        <pre class="m-0 min-w-0 flex-1 overflow-x-auto"><code class="bg-transparent p-0" data-install-command>{install.command}</code></pre>
          <PixelIcon name="copy" data-copy-icon class="size-5 shrink-0 text-foreground transition-colors group-hover:text-background" />
          <PixelIcon name="copy-check" data-copy-check-icon class="hidden size-5 shrink-0 text-foreground transition-colors group-hover:text-background" />
      </button>
      <div slot="label" class="inline-flex items-center gap-1 whitespace-nowrap leading-none">
        <span>Run</span>
        <InlineCode copyable value="seo start">seo start</InlineCode>
        <span>after install</span>
      </div>
    </DottedCard>
  </div>
  <div hidden data-agent-markdown="only">
    <p>Install the SEO CLI globally.</p>
    <pre><code>{install.command}</code></pre>
    <p>Run setup after installation.</p>
    <pre><code>seo start</code></pre>
  </div>
</section>

<script is:inline>
  const root = document.querySelector('[data-install-picker]')

  if (root) {
    const command = root.querySelector('[data-install-command]')
    const copyButton = root.querySelector('[data-copy-install-command]')
    const copyIcon = root.querySelector('[data-copy-icon]')
    const copyCheckIcon = root.querySelector('[data-copy-check-icon]')

    copyButton?.addEventListener('click', async () => {
      const value = command?.textContent ?? ''
      if (!value) return

      try {
        await navigator.clipboard.writeText(value)
      } catch {
        return
      }

      copyIcon?.classList.add('hidden')
      copyCheckIcon?.classList.remove('hidden')
      copyButton.setAttribute('aria-label', 'Copied install command')
      window.setTimeout(() => {
        copyIcon?.classList.remove('hidden')
        copyCheckIcon?.classList.add('hidden')
        copyButton.setAttribute('aria-label', `Copy ${value}`)
      }, 1500)
    })
  }
</script>
