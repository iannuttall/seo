{
  "name": "@seo/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm build:discovery && pnpm build:sitemap && astro build && node -e \"const fs=require('node:fs');for(const f of ['sitemap-index.xml','sitemap-0.xml'])fs.rmSync('dist/'+f,{force:true})\"",
    "build:discovery": "node scripts/build-agent-skills.mjs",
    "build:sitemap": "node scripts/build-sitemap.mjs",
    "clean": "rm -rf .astro dist .wrangler public/.well-known/agent-skills",
    "deploy": "pnpm build && wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "dev": "astro dev",
    "icons:generate": "node scripts/generate-pixelarticons.mjs",
    "predev": "pnpm build:discovery",
    "lint": "astro check",
    "preview": "astro preview",
    "test": "node --test scripts/site.test.mjs",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/markdown-remark": "^7.0.0",
    "@astrojs/react": "^6.0.0",
    "@seo/astro": "workspace:*",
    "@kiwa-ui/enhance": "^2.1.0",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.7",
    "clsx": "^2.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.110.0"
  }
}
