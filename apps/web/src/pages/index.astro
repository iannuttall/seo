---
import AgentDemo from '@/components/AgentDemo.astro'
import InstallPicker from '@/components/InstallPicker.astro'
import Logo from '@/components/Logo.astro'
import SiteLayout from '@/layouts/SiteLayout.astro'
import { productFacts } from '@/lib/facts'
import { site } from '@/lib/site'
---

<SiteLayout>
  <div class="shell home-shell">
    <section class="home-hero">
      <h1>
        Technical SEO skills
        <em class="scramble-text" data-scramble="for AI agents." aria-hidden="true">for AI agents.</em>
        <span class="visually-hidden">for AI agents.</span>
      </h1>
      <p class="lead">
        Your agent crawls the site, reads your Search Console and GA4 data,
        and hands back specific fixes. One local CLI for agents, developers,
        and CI.
      </p>
      <InstallPicker />
      <p class="install-note">Open source / Apache-2.0 / Working data stays local</p>
      <div class="hero-actions">
        <a class="button" href="/docs/getting-started">Get started</a>
        <a class="button secondary" href={site.repository}>View on GitHub</a>
      </div>
    </section>

    <section class="home-section intro-section" aria-labelledby="what-it-does">
      <div class="home-intro">
        <h2 id="what-it-does">Built on evidence from your own site.</h2>
        <p>
          SEO Skills combines live crawls with Search Console and GA4 data. It
          finds technical problems, shows the pages and queries they affect,
          and ranks the work so an agent can act without guessing.
        </p>
      </div>
      <ul class="feature-list">
        <li>
          <h3>Deterministic reports</h3>
          <p>Same input, same output. Stable schemas, rule ids, and date ranges an agent can rely on run after run.</p>
        </li>
        <li>
          <h3>Real priorities</h3>
          <p>Fixes ranked by technical severity, the URLs they touch, and the search value at stake.</p>
        </li>
        <li>
          <h3>Agent-ready context</h3>
          <p>Compact JSON and Markdown that explain the finding, the caveats, and the next command to run.</p>
        </li>
        <li>
          <h3>Local by default</h3>
          <p>No hosted backend, job queue, or account full of client data. Reports and tokens stay on your machine.</p>
        </li>
      </ul>
      <p class="scope-note">
        {productFacts.reports} discoverable reports / {productFacts.crawlerRules} crawler rules / {productFacts.skills} agent skills
      </p>
    </section>

    <section class="home-section report-section" aria-labelledby="show-working">
      <div class="home-intro">
        <h2 id="show-working">Reports that show their working.</h2>
        <p>
          Every recommendation stays connected to observed data. When the data
          is too sparse for a verdict, the report says so and skips the
          section, and follow-up commands keep the next request small enough
          for an agent context window.
        </p>
      </div>
      <AgentDemo />
    </section>

    <section class="home-section local-section" aria-labelledby="local-data">
      <Logo />
      <h2 id="local-data">Your clients' data stays on the machine doing the work.</h2>
      <p>
        OAuth tokens, project profiles, caches, and saved reports remain local.
        Requests go to Google and the sites you choose to inspect. There is no
        SEO account, analytics tracker, or hosted report database in the middle.
      </p>
      <a href="/privacy">Read the privacy model</a>
    </section>

    <section class="home-section closing-section" aria-labelledby="use-anywhere">
      <h2 id="use-anywhere">One report engine. CLI, Node, skills, and MCP.</h2>
      <p>Start with the guided setup, or give an agent the exact report schema it needs.</p>
      <div class="hero-actions">
        <a class="button" href="/docs/reports">Explore the reports</a>
        <a class="button secondary" href="/docs/agents">Connect an agent</a>
      </div>
    </section>
  </div>
</SiteLayout>
