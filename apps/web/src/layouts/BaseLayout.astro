---
import { site } from '@/lib/site'
import { canonicalUrl } from '@/lib/urls'
import '@/styles/globals.css'

type Props = {
  title: string
  description: string
  /** Wrap the slot in the centered content frame. Set false for pages that
   * build their own full-bleed sections, such as the marketing home. */
  framed?: boolean
  canonicalPath?: string
  noindex?: boolean
}

const {
  title,
  description,
  framed = true,
  canonicalPath = Astro.url.pathname,
  noindex = false,
} = Astro.props
const pageTitle = title.includes(site.name) ? title : `${title} | ${site.name}`
const canonical = canonicalUrl(canonicalPath)
const year = new Date().getFullYear()
const schema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: site.packageName,
  alternateName: ['SEO Skills', site.name],
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Linux, macOS, Windows',
  description,
  url: canonical,
  downloadUrl: site.npm,
  codeRepository: site.repository,
  license: 'https://www.apache.org/licenses/LICENSE-2.0',
  isAccessibleForFree: true,
}

const navClass =
  'text-sm text-foreground-muted underline-offset-4 hover:text-foreground hover:underline'
const footerGroups = [
  {
    heading: 'Product',
    links: [
      { label: 'Home', href: '/' },
      { label: 'Docs', href: '/docs' },
      { label: 'Reports', href: '/docs/reports' },
    ],
  },
  {
    heading: 'Agents',
    links: [
      { label: 'Getting started', href: '/docs/getting-started' },
      { label: 'Local MCP', href: '/docs/mcp' },
      { label: 'Agent skills', href: '/docs/skills' },
    ],
  },
]
const footerLinkClass =
  'text-base text-foreground-muted underline-offset-2 hover:text-foreground hover:underline hover:decoration-dotted'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1c1c1c" media="(prefers-color-scheme: dark)" />
    {noindex ? <meta name="robots" content="noindex, follow" /> : null}
    <link rel="canonical" href={canonical} />
    <link rel="preload" href="/fonts/InterVF.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${site.url}/og.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={site.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${site.url}/og.png`} />
    <meta name="twitter:image:alt" content={site.name} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <div class="flex min-h-screen flex-col">
      <header class="site-frame flex items-center justify-between gap-6 py-4">
        <a
          href="/"
          class="inline-flex items-center gap-1.5 text-base font-bold leading-none tracking-normal text-foreground no-underline"
        >
          <svg
            class="size-5"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              fill="currentColor"
              d="M12,8c-2.2,0-4,1.8-4,4s1.8,4,4,4s4-1.8,4-4C16,9.8,14.2,8,12,8z M3,9L3,9c0.6,0,1-0.4,1-1V5c0-0.6,0.4-1,1-1h3 c0.6,0,1-0.4,1-1S8.6,2,8,2H5C3.3,2,2,3.3,2,5v3C2,8.6,2.4,9,3,9z M8,20H5c-0.6,0-1-0.4-1-1v-3c0-0.6-0.4-1-1-1s-1,0.4-1,1v3 c0,1.7,1.3,3,3,3h3c0.6,0,1-0.4,1-1S8.6,20,8,20z M21,15L21,15c-0.6,0-1,0.4-1,1v3c0,0.6-0.4,1-1,1h-3c-0.6,0-1,0.4-1,1s0.4,1,1,1h3 c1.7,0,3-1.3,3-3v-3C22,15.4,21.6,15,21,15z M19,2h-3c-0.6,0-1,0.4-1,1s0.4,1,1,1h3c0.6,0,1,0.4,1,1v3c0,0.6,0.4,1,1,1s1-0.4,1-1V5 C22,3.3,20.7,2,19,2z"
            />
          </svg>
          <span>{site.name}</span>
        </a>
        <nav class="flex items-center gap-5" aria-label="Main navigation">
          <a class={navClass} href="/docs">Docs</a>
          <a class={navClass} href={site.repository} target="_blank" rel="noreferrer">GitHub</a>
        </nav>
      </header>

      {
        framed ? (
          <div class="site-frame w-full flex-1 py-10">
            <slot />
          </div>
        ) : (
          <div class="flex-1">
            <slot />
          </div>
        )
      }

      <footer class="bg-muted py-12">
        <div class="site-frame space-y-10">
          <div class="grid gap-8 sm:grid-cols-2">
            {
              footerGroups.map((group) => (
                <div class="space-y-3">
                  <h3 class="text-base font-semibold text-foreground">{group.heading}</h3>
                  <ul class="flex flex-col gap-2">
                    {group.links.map((link) => (
                      <li>
                        <a class={footerLinkClass} href={link.href}>{link.label}</a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))
            }
          </div>
          <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <p class="text-base text-foreground-muted">&copy; {year} {site.name}</p>
            <div class="flex flex-wrap gap-4">
              <a class={footerLinkClass} href="/privacy">Privacy</a>
              <a class={footerLinkClass} href="/terms">Terms</a>
              <a class={footerLinkClass} href="/security">Security</a>
              <a class={footerLinkClass} href="/trademarks">Trademarks</a>
            </div>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
