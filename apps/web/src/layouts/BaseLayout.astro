---
import FooterDither from '@/components/FooterDither.astro'
import OgTemplate from '@/components/OgTemplate.astro'
import { site } from '@/lib/site'
import {
  type PageSchemaType,
  type SchemaBreadcrumb,
  pageSchema,
} from '@/lib/schema'
import { canonicalUrl } from '@/lib/urls'
import '@/styles/globals.css'

type Props = {
  title: string
  titleBrandPosition?: 'prefix' | 'suffix'
  description: string
  framed?: boolean
  canonicalPath?: string
  noindex?: boolean
  schemaType?: PageSchemaType
  breadcrumbs?: readonly SchemaBreadcrumb[]
  dateModified?: string
  datePublished?: string
}

const {
  title,
  titleBrandPosition = 'suffix',
  description,
  framed = true,
  canonicalPath = Astro.url.pathname,
  noindex = false,
  schemaType = 'WebPage',
  breadcrumbs,
  dateModified,
  datePublished,
} = Astro.props
const pageTitle = title.includes(site.name)
  ? title
  : titleBrandPosition === 'prefix'
    ? `${site.name} | ${title}`
    : `${title} | ${site.name}`
const canonical = canonicalUrl(canonicalPath)
const ogImage = `https://og.ian.is/?url=${encodeURIComponent(canonical)}&v=2`
const year = new Date().getFullYear()
const isLocalHost = ['localhost', '127.0.0.1', '::1', '[::1]'].includes(
  Astro.url.hostname,
)
const showClicky = import.meta.env.PROD && !isLocalHost && site.clickySiteId
const schema = pageSchema({
  breadcrumbs,
  canonical,
  dateModified,
  datePublished,
  description,
  title: pageTitle,
  type: schemaType,
})

const footerGroups = [
  {
    heading: 'Product',
    links: [
      { label: 'Home', href: '/' },
      { label: 'Docs', href: '/docs' },
      { label: 'Reports', href: '/docs/reports' },
    ],
  },
  {
    heading: 'Agents',
    links: [
      { label: 'Getting started', href: '/docs/getting-started' },
      { label: 'Local MCP', href: '/docs/mcp' },
      { label: 'Agent skill', href: '/docs/skill' },
    ],
  },
  {
    heading: 'Legal',
    links: [
      { label: 'Privacy', href: '/privacy' },
      { label: 'Terms', href: '/terms' },
      { label: 'Cookies', href: '/cookies' },
      { label: 'Security', href: '/security' },
      { label: 'Trademarks', href: '/trademarks' },
    ],
  },
]

// Interesting ways to describe a project; the branded footer picks one at
// random on each load. The corporate theme will drop this for a plain byline.
// Every entry has to read naturally in "an Ian Nuttall ___".
const projectThings = [
  'joint',
  'jam',
  'vibe',
  'thing',
  'thang',
  'production',
  'creation',
  'contraption',
  'invention',
  'endeavour',
  'venture',
  'operation',
  'undertaking',
  'experiment',
  'side quest',
  'side hustle',
  'passion project',
  'pet project',
  'labor of love',
  'science project',
  'art project',
  'fever dream',
  'brainchild',
  'obsession',
  'fixation',
  'racket',
  'scheme',
  'caper',
  'escapade',
  'romp',
  'odyssey',
  'saga',
  'gambit',
  'shindig',
  'jamboree',
  'extravaganza',
  'spectacle',
  'situation',
  'expedition',
  'rabbit hole',
  'weekend build',
  'mixtape',
  'remix',
  'b-side',
  'deep cut',
  'banger',
  'slopfest',
  'clanger',
  'faff',
  'kerfuffle',
  'shenanigan',
  'folly',
  'hackjob',
  'eval',
  'gpt wrapper',
  'vibe code',
  'hallucination',
  'token burner',
  'prompt spiral',
  'ting',
  'groove',
  'number',
  'bit',
  'doodle',
  'sketch',
  'zine',
  'manifesto',
  'love letter',
  'special',
  'original',
]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <script is:inline>
      if (new URLSearchParams(window.location.search).has('og')) {
        document.documentElement.dataset.ogPreview = 'true'
      }
    </script>
    <style is:global>
      html[data-og-preview='true'] [data-site-shell] {
        display: none;
      }

      html[data-og-preview='true'],
      html[data-og-preview='true'] body {
        width: 1200px;
        height: 630px;
        margin: 0;
        overflow: hidden;
      }
    </style>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />
    {noindex ? <meta name="robots" content="noindex, follow" /> : null}
    <link rel="canonical" href={canonical} />
    <link rel="preload" href="/fonts/MartianGroteskVF.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/MartianMonoVF.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-light.png?v=3" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-dark.png?v=3" media="(prefers-color-scheme: dark)" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={site.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={site.name} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    {
      showClicky ? (
        <>
          <script is:inline>
            window.clicky_custom = window.clicky_custom || {}
            window.clicky_custom.cookies_disable = 1
          </script>
          <script
            is:inline
            async
            data-id={site.clickySiteId}
            src="//static.getclicky.com/js"
          />
        </>
      ) : null
    }
    <title>{pageTitle}</title>
  </head>
  <body class="bg-background font-mono text-foreground">
    <div class="flex min-h-screen flex-col overflow-hidden bg-background text-foreground" data-site-shell>
      <header class="sticky top-0 z-50 border-b border-header-border bg-header text-header-foreground selection:bg-header-foreground/25 selection:text-header-foreground">
        <div class="mx-auto flex w-full max-w-4xl items-center justify-between px-8 py-3 md:px-12">
          <a class="underline underline-offset-2 hover:decoration-dotted" href="/">{site.name}</a>
          <nav class="flex items-center gap-3" aria-label="Main navigation">
            <a class="underline underline-offset-2 hover:decoration-dotted" href="/docs">Docs</a>
            <a class="underline underline-offset-2 hover:decoration-dotted" href={site.repository} target="_blank" rel="noreferrer">GitHub</a>
          </nav>
        </div>
      </header>

      <div class="flex-1 bg-background">
        {
          framed ? (
            <div class="mx-auto w-full max-w-4xl px-8 py-12 md:px-12">
              <slot />
            </div>
          ) : (
            <slot />
          )
        }
      </div>

      <footer class="relative overflow-hidden border-t-2 border-nav bg-primary py-8 font-sans text-sm text-primary-foreground selection:bg-primary-foreground/25 selection:text-primary-foreground">
        <FooterDither />
        <div class="relative mx-auto w-full max-w-4xl px-8 md:px-12">
          <div class="grid gap-8 sm:grid-cols-3">
            {
              footerGroups.map((group) => (
                <div class="space-y-3">
                  <h3 class="font-mono text-sm font-normal leading-5 tracking-wide">{group.heading}</h3>
                  <ul class="flex flex-col gap-2">
                    {group.links.map((link) => (
                      <li>
                        <a class="underline underline-offset-2 hover:decoration-dotted" href={link.href}>{link.label}</a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))
            }
          </div>
          <div class="mt-8 text-primary-foreground/80">
            <p>
              &copy; {year} {site.name}, an{' '}
              <a class="underline underline-offset-2 hover:decoration-dotted" href="https://ian.is" target="_blank" rel="noreferrer">Ian Nuttall</a>{' '}
              <span data-project-thing>joint</span>
            </p>
          </div>
        </div>
      </footer>
      <script is:inline define:vars={{ projectThings }}>
        const thing = document.querySelector('[data-project-thing]')
        if (thing) {
          thing.textContent = projectThings[Math.floor(Math.random() * projectThings.length)]
        }
      </script>
      <script>
        // The .code-frame chrome is rendered at build time (rehype plugin and
        // CopyCode); this only binds the copy behaviour.
        document.querySelectorAll('[data-code-copy]').forEach((button) => {
          if (!(button instanceof HTMLElement)) return
          const code = button.closest('.code-frame')?.querySelector('pre code')
          const copyIcon = button.querySelector('[data-copy-icon]')
          const checkIcon = button.querySelector('[data-copy-check-icon]')
          button.addEventListener('click', async () => {
            try {
              await navigator.clipboard.writeText(code?.textContent ?? '')
            } catch {
              return
            }
            copyIcon?.classList.add('hidden')
            checkIcon?.classList.remove('hidden')
            window.setTimeout(() => {
              copyIcon?.classList.remove('hidden')
              checkIcon?.classList.add('hidden')
            }, 1500)
          })
        })
      </script>
    </div>
    <template data-og-template data-og-width="1200" data-og-height="630">
      <OgTemplate title={title} description={description} />
    </template>
    <script is:inline>
      const template = document.querySelector('template[data-og-template]')

      if (document.documentElement.dataset.ogPreview === 'true' && template) {
        document.body.replaceChildren(template.content.cloneNode(true))
      }

      window.__OG_READY__ = true
    </script>
  </body>
</html>
