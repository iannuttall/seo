{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "files": {
    "includes": [
      "**",
      "!!**/node_modules",
      "!!**/dist",
      "!!**/dist-firefox",
      "!!**/.astro",
      "!!apps/web/**/*.astro",
      "!!**/public/assets",
      "!!**/.turbo",
      "!!**/.wrangler",
      "!!**/pnpm-lock.yaml",
      "!!**/package-lock.json",
      "!!**/yarn.lock",
      "!!**/bun.lock",
      "!!**/bun.lockb",
      "!!**/biome.json",
      "!!**/tsconfig*.json",
      "!!**/*.config.ts",
      "!!**/*.config.cts",
      "!!**/*.config.mts",
      "!!**/*.config.js",
      "!!**/*.config.cjs",
      "!!**/*.config.mjs",
      "!!**/*.config.json",
      "!!**/wrangler.toml",
      "!!**/.submit",
      "!!**/.context",
      "!!**/.vscode",
      "!!**/tmp",
      "!!**/worker-configuration.d.ts",
      "!!**/routeTree.gen.ts",
      "!!**/routeTree.gen.tsx",
      "!!**/styles.css"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "style": {
        "noExcessiveLinesPerFile": {
          "level": "error",
          "options": {
            "maxLines": 1000,
            "skipBlankLines": true
          }
        }
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "css": {
    "parser": {
      "cssModules": false,
      "tailwindDirectives": true
    },
    "linter": {
      "enabled": false
    },
    "formatter": {
      "enabled": false
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "semicolons": "asNeeded"
    }
  }
}
