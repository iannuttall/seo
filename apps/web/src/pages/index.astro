---
import HeroPanel from '@/components/HeroPanel.astro'
import InstallPicker from '@/components/InstallPicker.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import {
  Accordion,
  AccordionContent,
  AccordionItem,
  AccordionTrigger,
} from '@/components/ui/accordion'
import { reports } from '@/content/reports'
import { categoryLabels, reportPath } from '@/content/reports/helpers'
import type { ReportCategory } from '@/content/reports/types'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { site } from '@/lib/site'

const categoryOrder: readonly ReportCategory[] = [
  'setup',
  'diagnosis',
  'opportunities',
  'crawl',
  'monitoring',
  'reporting',
  'experiments',
  'ai-search',
  'workflows',
]

const faqs = [
  {
    question: 'Does SEO Skills CLI include an AI agent?',
    answer:
      'No. It gives Claude, Codex, Cursor, and other agents reliable SEO tools and structured evidence. Your agent still does the reasoning, writing, and implementation work.',
  },
  {
    question: 'Why connect Search Console?',
    answer:
      'Search Console adds the queries, pages, clicks, impressions, CTR, position, and index evidence needed to find real opportunities on a site you can access. The CLI requests read-only access.',
  },
  {
    question: 'Is GA4 required?',
    answer:
      'No. Crawls and Search Console reports work without GA4. Connect it when traffic, landing-page, engagement, or conversion context would change how you prioritise the work.',
  },
  {
    question: 'Does my site data leave my machine?',
    answer:
      'Reports, project profiles, tokens, crawls, and caches stay local. The CLI only sends the requests needed to fetch the site and call the Google APIs you connect.',
  },
  {
    question: 'Can it change my site?',
    answer:
      'The SEO tools inspect and report. An agent can use that evidence to edit code or content in a separate workflow, but the CLI does not publish changes to your site by itself.',
  },
  {
    question: 'Do I need MCP?',
    answer:
      'No. Use the CLI directly, import the package in TypeScript, or run it in CI. MCP is the easiest way to give a compatible agent the same local report engine.',
  },
  {
    question: 'Why install both the CLI and the skills?',
    answer:
      'The CLI does the work. The skills teach an agent which report to choose, how to run it, what the result means, and which follow-up is worth the context. Agents work best with both.',
  },
  {
    question: 'Which report should I run first?',
    answer:
      'Run seo report after setup. It checks the evidence available for the project, explains skipped sections, ranks the first investigation queue, and points to focused follow-up reports.',
  },
]
---

<BaseLayout
  title="SEO Skills CLI for AI agents and technical SEO audits"
  description={site.description}
  framed={false}
>
  <main data-agent-content="true">
    <section class="flex flex-col border-b border-border bg-background pt-4 text-foreground">
      <div class="site-frame">
        <div class="flex flex-col gap-8 pt-16 sm:pt-24">
          <div class="flex max-w-2xl flex-col gap-4">
            <h1 class="text-pretty text-3xl font-medium -tracking-[0.5px] xl:text-4xl xl:-tracking-[0.7px]">
              Turn your agents into an SEO team that grows your organic and AI search visibility.
            </h1>
            <p class="text-pretty text-2xl/8 font-medium -tracking-[0.2px] text-foreground-muted xl:text-3xl/10 xl:-tracking-[0.4px]">
              Local-first SEO tools to find and fix issues, measure performance, and improve
              visibility through one CLI or MCP server.
            </p>
          </div>
          <InstallPicker />
        </div>
      </div>
    </section>

    <div class="space-y-24 py-24">
      <section class="site-frame grid grid-cols-1 gap-2 sm:grid-cols-2">
        <div class="rounded-lg bg-muted p-8">
          <h2 class="text-lg font-semibold">Your agent audits the site without you.</h2>
          <p class="mt-2 text-base leading-7 text-foreground-muted">
            It crawls the site, finds technical problems, and hands back affected URLs and specific
            next steps while you stay in your editor.
          </p>
        </div>
        <div class="rounded-lg bg-muted p-8">
          <h2 class="text-lg font-semibold">Use the search data you already own.</h2>
          <p class="mt-2 text-base leading-7 text-foreground-muted">
            Join crawl findings with read-only Search Console and GA4 data so your agent can rank
            work by observed demand, not a generic score.
          </p>
        </div>
        <div class="rounded-lg bg-muted p-8">
          <h2 class="text-lg font-semibold">It works where your agents already work.</h2>
          <p class="mt-2 text-base leading-7 text-foreground-muted">
            Run the same reports through the CLI, local MCP, TypeScript package, or CI and receive
            structured JSON or readable Markdown.
          </p>
        </div>
        <div class="rounded-lg bg-muted p-8">
          <h2 class="text-lg font-semibold">Catch regressions before they become normal.</h2>
          <p class="mt-2 text-base leading-7 text-foreground-muted">
            Save crawl evidence locally, compare like-for-like snapshots, and trace changed pages
            and rules after a release.
          </p>
        </div>
      </section>

      <section class="site-frame">
        <SectionHeading
          eyebrow="See your agent do the work"
          text="It reads crawl findings and first-party search data, runs the focused follow-up, and keeps every recommendation tied to evidence you can inspect."
        />
        <HeroPanel />
      </section>

      <section class="site-frame">
        <SectionHeading
          eyebrow="Everything a technical SEO investigation needs"
          text={`${reports.length} reports across crawl health, search opportunities, monitoring, AI search evidence, experiments, and reporting.`}
        />
        <div class="grid grid-cols-1 gap-x-10 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
          {
            categoryOrder.map((category) => (
              <div>
                <h3 class="text-lg font-medium text-foreground">{categoryLabels[category]}</h3>
                <ul class="mt-3 flex flex-col gap-1.5 text-base text-foreground-muted">
                  {reports
                    .filter((report) => report.category === category)
                    .map((report) => (
                      <li>
                        <a class="body-link" href={reportPath(report.id)}>
                          {report.name}
                        </a>
                      </li>
                    ))}
                </ul>
              </div>
            ))
          }
        </div>
      </section>

      <section class="site-frame">
        <div class="border-t border-border pt-12">
          <div class="max-w-2xl">
            <h2 class="text-pretty text-2xl font-medium -tracking-[0.4px] text-foreground xl:text-3xl xl:-tracking-[0.6px]">
              Before you give an agent access to a site
            </h2>
            <p class="mt-4 text-pretty text-xl/7 font-medium -tracking-[0.15px] text-foreground-muted xl:text-2xl/8 xl:-tracking-[0.3px]">
              The report engine is local, Google access is read-only, and your agent gets evidence
              instead of another dashboard to interpret.
            </p>
          </div>

          <Accordion class="mt-6 space-y-2">
            {
              faqs.map((item) => (
                <AccordionItem value={item.question}>
                  <AccordionTrigger>{item.question}</AccordionTrigger>
                  <AccordionContent>{item.answer}</AccordionContent>
                </AccordionItem>
              ))
            }
          </Accordion>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
