---
import type { HTMLAttributes } from 'astro/types'

type Props =
  | (HTMLAttributes<'button'> & { href?: undefined })
  | (HTMLAttributes<'a'> & { href: string })

const { class: className, ...props } = Astro.props as Props
const anchorProps = typeof props.href === 'string' ? (props as HTMLAttributes<'a'>) : undefined
const buttonProps = anchorProps ? undefined : (props as HTMLAttributes<'button'>)

// The Turbopuffer button in brand colors: inset highlight and shade give the
// 3D face, active presses it inward. Selection colors are pinned so the
// global primary-tinted selection never clashes with the primary background.
const classes = [
  'group relative grid cursor-pointer items-center justify-center whitespace-nowrap border border-primary-active bg-primary font-medium text-primary-foreground',
  'shadow-btn transition-all hover:bg-primary-hover hover:shadow-btn-hover active:bg-primary-active active:shadow-btn-active',
  'focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary',
  'selection:bg-primary-foreground selection:text-primary',
  className,
]
---

{
  anchorProps ? (
    <a {...anchorProps} class:list={classes}>
      <slot />
    </a>
  ) : (
    <button {...buttonProps} class:list={classes}>
      <slot />
    </button>
  )
}
