---
import DottedCard from '@/components/DottedCard.astro'
import InstallPicker from '@/components/InstallPicker.astro'
import NavCard from '@/components/NavCard.astro'
import PageHeader from '@/components/PageHeader.astro'
import CopyCode from '@/components/docs/CopyCode.astro'
import ReportUsageTabs from '@/components/reports/ReportUsageTabs.astro'
import { humanReportCommand } from '@/content/reports/commands'
import { describeCommand, reportCommand, reportPath } from '@/content/reports/helpers'
import { reportsById } from '@/content/reports'
import { reportSources } from '@/content/reports/sources'
import type { ResolvedReportGuide } from '@/content/reports/guides'
import type { ReportEditorial } from '@/content/reports/types'

type Props = {
  report: ReportEditorial
  guide: ResolvedReportGuide
}

const { report, guide } = Astro.props
const humanCommand = humanReportCommand(report.id)

if (!humanCommand) {
  throw new Error(`Missing human command for ${report.id}`)
}

const facts = [
  ['Best for', 'Your first technical crawl'],
  ['Start with', 'A public site URL'],
  ['You get', 'Prioritized issues and affected pages'],
  ['Saved for', 'Comparisons and follow-up audits'],
] as const

const checkGroups = [
  {
    label: 'Page access',
    detail: 'Response codes, redirects, robots rules and crawl paths.',
  },
  {
    label: 'Indexing signals',
    detail: 'Canonicals, meta robots directives and sitemap discovery.',
  },
  {
    label: 'Page SEO',
    detail: 'Titles, descriptions, headings and content signals.',
  },
  {
    label: 'Site structure',
    detail: 'Internal links, structured data, hreflang, security and mobile signals.',
  },
] as const

const resultRows = [
  {
    label: 'Coverage',
    detail: 'Check how many pages were fetched, skipped or blocked before trusting the issue counts.',
  },
  {
    label: 'Top fixes',
    detail: 'Start with the short implementation queue instead of treating every warning as urgent.',
  },
  {
    label: 'Affected pages',
    detail: 'Open the URL evidence when you need to see exactly where a rule fired.',
  },
  {
    label: 'Warnings',
    detail: 'Read these before acting. They show where limits or missing data changed what the audit could check.',
  },
] as const

const alternatives = [
  {
    href: reportPath('audit-page'),
    title: reportsById.get('audit-page')?.name ?? 'Audit one page',
    detail: 'Use this when you already know the URL and do not need to discover the rest of the site.',
  },
  {
    href: reportPath('search-performance-overview'),
    title: reportsById.get('search-performance-overview')?.name ?? 'Review search performance',
    detail: 'Use this when clicks or impressions changed and you need Search Console evidence.',
  },
] as const

const nextAudits = [
  {
    id: 'top-fixes',
    detail: 'Turn the saved crawl into a short implementation queue.',
  },
  {
    id: 'affected-urls',
    detail: 'List the pages affected by one issue or rule.',
  },
  {
    id: 'compare-crawls',
    detail: 'Check what changed after a release or SEO fix.',
  },
].map(({ id, detail }) => ({
  id,
  detail,
  href: reportPath(id),
  title: reportsById.get(id)?.name ?? id,
}))

const sources = report.sources.map((key) => reportSources[key])
const describeValue = describeCommand(report)
const runValue = reportCommand(report)
const mcpDescribeInput = JSON.stringify({ id: report.id }, null, 2)
const mcpRunInput = JSON.stringify(
  { id: report.id, params: report.exampleParams },
  null,
  2,
)
const libraryExample = `import { executeReport } from 'seo/mcp'

const result = await executeReport(
  '${report.id}',
  ${JSON.stringify(report.exampleParams, null, 2)},
)

console.log(result)`
---

<PageHeader
  title={guide.seo?.heading ?? guide.name}
  description={guide.lead}
  align="left"
  class="mb-8"
/>

<section aria-labelledby="install-and-run" class="mb-14">
  <div class="docs-prose">
    <h2 id="install-and-run">Install and run the audit</h2>
    <p>
      Install the CLI once, then run <code>seo start</code> to set up your site.
      Once setup is complete you can run the audit yourself or ask your agent
      to run it for you.
    </p>
  </div>
  <div class="mt-5 space-y-7">
    <InstallPicker />
    <div class="docs-prose">
    <CopyCode
      label="After setup you can run the site crawl audit yourself or ask your agent to run it."
      value={humanCommand.command}
    />
    </div>
  </div>
</section>

<section aria-labelledby="what-you-get" class="mb-14 space-y-5">
  <div class="space-y-2">
    <h2 id="what-you-get" class="font-mono text-xl font-normal leading-tight">
      What you get from this audit
    </h2>
    <p class="font-sans text-[0.9375rem] font-light leading-7">
      Once the crawl finishes you get a grouped list of technical SEO issues,
      the URLs affected and the evidence behind each finding. Start with the
      issues that matter, open the example pages to confirm what is happening
      and save the crawl so you or your agent can run focused follow-up audits
      without fetching the whole site again.
    </p>
  </div>
  <DottedCard patternId="site-crawl-facts">
    <dl class="divide-y divide-border">
      {
        facts.map(([label, value]) => (
          <div class="grid gap-1 px-5 py-4 sm:grid-cols-[9rem_1fr] sm:items-baseline sm:gap-6">
            <dt class="font-sans text-sm font-medium">{label}</dt>
            <dd class="text-xs leading-5 text-foreground-muted sm:text-right">{value}</dd>
          </div>
        ))
      }
    </dl>
  </DottedCard>
</section>

<section aria-labelledby="checks" class="mb-14 space-y-5">
  <div class="space-y-2">
    <h2 id="checks" class="font-mono text-xl font-normal leading-tight">
      What the site crawl checks
    </h2>
    <p class="font-sans text-[0.9375rem] font-light leading-7">
      The crawler follows links across your site and checks every page it can
      reach within the limits you set. Every finding stays tied to the page and
      rule that produced it, so you can inspect the real problem instead of
      trying to decode a mystery score.
    </p>
  </div>
  <DottedCard patternId="site-crawl-checks">
    <div class="divide-y divide-border">
      {
        checkGroups.map(({ label, detail }) => (
          <div class="grid gap-2 px-5 py-4 sm:grid-cols-[10rem_1fr] sm:gap-6">
            <h3 class="font-mono text-sm font-normal">{label}</h3>
            <p class="font-sans text-sm font-light leading-6 text-foreground-muted">{detail}</p>
          </div>
        ))
      }
    </div>
  </DottedCard>
</section>

<section aria-labelledby="read-results" class="mb-14 space-y-5">
  <div class="space-y-2">
    <h2 id="read-results" class="font-mono text-xl font-normal leading-tight">
      Read the coverage before the issue count
    </h2>
    <p class="font-sans text-[0.9375rem] font-light leading-7">
      Check what the crawler actually reached before working through the issue
      list. A clean result means little if the pages you care about were
      blocked, skipped or outside the crawl limit.
    </p>
  </div>
  <DottedCard patternId="site-crawl-results">
    <table class="w-full table-fixed border-collapse text-left">
      <thead class="border-b-2 border-nav bg-background">
        <tr>
          <th class="w-24 px-3 py-3 font-mono text-xs font-normal sm:w-40 sm:px-5 sm:text-sm">
            Read first
          </th>
          <th class="px-3 py-3 font-mono text-xs font-normal sm:px-5 sm:text-sm">
            Why it matters
          </th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        {
          resultRows.map(({ label, detail }) => (
            <tr>
              <th class="px-3 py-4 align-top font-sans text-xs font-medium sm:px-5 sm:text-sm">
                {label}
              </th>
              <td class="break-words px-3 py-4 font-sans text-xs font-light leading-5 text-foreground-muted sm:px-5 sm:text-sm sm:leading-6">
                {detail}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </DottedCard>
</section>

<section aria-labelledby="cannot-prove" class="mb-14 space-y-5">
  <DottedCard patternId="site-crawl-limits" inverted>
    <div class="space-y-5 p-5 sm:p-6">
      <h2 id="cannot-prove" class="font-mono text-xl font-normal leading-tight">
        What this audit cannot prove
      </h2>
      <div class="space-y-3 font-sans text-sm font-light leading-6">
        <p>
          This is a local crawl, so it cannot prove that Google indexed a page or
          saw the same version.
        </p>
        <p>
          Pages outside the crawl limits or discovery path remain unchecked. A
          blocked fetch can also hide an issue without fixing it.
        </p>
      </div>
    </div>
  </DottedCard>
</section>

<section aria-labelledby="different-tool" class="mb-14 space-y-5">
  <div class="space-y-2">
    <h2 id="different-tool" class="font-mono text-xl font-normal leading-tight">
      Use a different tool for these jobs
    </h2>
    <p class="font-sans text-[0.9375rem] font-light leading-7">
      A site crawl is deliberately broad. If you already know the page or the
      search-performance question you need to answer, use a focused audit and
      get to the useful evidence faster.
    </p>
  </div>
  <div class="grid gap-5 sm:grid-cols-2">
    {
      alternatives.map(({ href, title, detail }) => (
        <NavCard title={title} description={detail} href={href} />
      ))
    }
  </div>
</section>

<section aria-labelledby="advanced-usage" class="mb-14 space-y-5">
  <div class="space-y-2">
    <h2 id="advanced-usage" class="font-mono text-xl font-normal leading-tight">
      Use the audit with an agent or in code
    </h2>
    <p class="font-sans text-[0.9375rem] font-light leading-7">
      Most people can use the crawl command above. These options let an agent,
      script or application run the same audit and get the same evidence,
      warnings and crawl limits.
    </p>
  </div>
  <ReportUsageTabs
    {describeValue}
    {runValue}
    {mcpDescribeInput}
    {mcpRunInput}
    {libraryExample}
  />
</section>

<section aria-labelledby="next-audits" class="mb-14 space-y-5">
  <div class="space-y-2">
    <h2 id="next-audits" class="font-mono text-xl font-normal leading-tight">
      Reuse the saved crawl
    </h2>
    <p class="font-sans text-[0.9375rem] font-light leading-7">
      The saved crawl is your technical baseline. Use it to turn one issue into
      a list of affected pages, build a smaller fix queue or compare the site
      again after a release without starting the investigation from scratch.
    </p>
  </div>
  <div class="grid gap-5 sm:grid-cols-3">
    {
      nextAudits.map(({ href, title, detail }) => (
        <NavCard title={title} description={detail} href={href} />
      ))
    }
  </div>
</section>

{
  sources.length ? (
    <section aria-labelledby="sources" class="space-y-4">
      <h2 id="sources" class="font-mono text-xl font-normal leading-tight">
        Google rules used by the audit
      </h2>
      <p class="font-sans text-[0.9375rem] font-light leading-7">
        These primary sources define the crawl and indexing controls used by the audit.
      </p>
      <ul class="space-y-2 font-sans text-sm font-light leading-6">
        {sources.map((source) => (
          <li>
            <a
              class="text-primary underline underline-offset-4 hover:decoration-dotted"
              href={source.url}
              target="_blank"
              rel="noreferrer"
            >
              {source.label}
            </a>
          </li>
        ))}
      </ul>
    </section>
  ) : null
}
