---
import { editorialReports } from '@/content/reports'
import { reportCollections } from '@/content/reports/collections'
import { resolveReportGuide } from '@/content/reports/guides'
import { reportPath } from '@/content/reports/helpers'

const catalogCollections = reportCollections.map((collection) => ({
  ...collection,
  reports: collection.reports.map(([id, label]) => {
    const report = editorialReports.find((item) => item.id === id)
    if (!report) throw new Error(`Missing report ${id} in docs catalog.`)
    return { report, label }
  }),
}))
---

<div class="mt-10 space-y-14">
  {
    catalogCollections.map((collection) => {
      return (
        <section>
          <header class="max-w-2xl">
            <h2 class="text-2xl/8 font-medium text-foreground">
              {collection.title}
            </h2>
            <p class="mt-2 text-base/7 text-foreground-muted">
              {collection.introduction}
            </p>
          </header>

          <div class="mt-6 grid gap-2 sm:grid-cols-2">
            {collection.reports.map(({ report, label }) => {
              const guide = resolveReportGuide(report)
              return (
                <a
                  href={reportPath(report.id)}
                  class="group flex min-h-40 flex-col rounded-lg bg-muted p-6 no-underline transition-colors hover:bg-secondary-hover"
                >
                  <span class="block text-base font-medium text-foreground">
                    {label}
                  </span>
                  <span class="mt-3 block text-sm/6 text-foreground-muted">
                    {guide.summary}
                  </span>
                  <span class="mt-auto pt-5 font-mono text-xs text-foreground-soft">
                    {report.id}
                  </span>
                </a>
              )
            })}
          </div>
        </section>
      )
    })
  }
</div>
