---
import SiteLayout from '@/layouts/SiteLayout.astro'
---

<SiteLayout
  title="Page not found"
  description="The requested seoskills.dev page could not be found."
  canonicalPath="/404"
  noindex
>
  <section class="shell not-found prose">
    <h1>404: That page is not here.</h1>
    <p>
      Try the <a href="/docs">documentation</a>, go back to the
      <a href="/">home page</a>, or report a broken link through
      <a href="https://github.com/iannuttall/seo/issues">GitHub Issues</a>.
    </p>
  </section>
</SiteLayout>
