---
// Scripted agent session demo, rendered by Alpine from the script in
// src/scripts/agent-demo.ts. The noscript block keeps the panel useful
// when JavaScript is unavailable.
const claudePath =
  'm4.7144 15.9555 4.7174-2.6471.079-.2307-.079-.1275h-.2307l-.7893-.0486-2.6956-.0729-2.3375-.0971-2.2646-.1214-.5707-.1215-.5343-.7042.0546-.3522.4797-.3218.686.0608 1.5179.1032 2.2767.1578 1.6514.0972 2.4468.255h.3886l.0546-.1579-.1336-.0971-.1032-.0972L6.973 9.8356l-2.55-1.6879-1.3356-.9714-.7225-.4918-.3643-.4614-.1578-1.0078.6557-.7225.8803.0607.2246.0607.8925.686 1.9064 1.4754 2.4893 1.8336.3643.3035.1457-.1032.0182-.0728-.164-.2733-1.3539-2.4467-1.445-2.4893-.6435-1.032-.17-.6194c-.0607-.255-.1032-.4674-.1032-.7285L6.287.1335 6.6997 0l.9957.1336.419.3642.6192 1.4147 1.0018 2.2282 1.5543 3.0296.4553.8985.2429.8318.091.255h.1579v-.1457l.1275-1.706.2368-2.0947.2307-2.6957.0789-.7589.3764-.9107.7468-.4918.5828.2793.4797.686-.0668.4433-.2853 1.8517-.5586 2.9021-.3643 1.9429h.2125l.2429-.2429.9835-1.3053 1.6514-2.0643.7286-.8196.85-.9046.5464-.4311h1.0321l.759 1.1293-.34 1.1657-1.0625 1.3478-.8804 1.1414-1.2628 1.7-.7893 1.36.0729.1093.1882-.0183 2.8535-.607 1.5421-.2794 1.8396-.3157.8318.3886.091.3946-.3278.8075-1.967.4857-2.3072.4614-3.4364.8136-.0425.0304.0486.0607 1.5482.1457.6618.0364h1.621l3.0175.2247.7892.522.4736.6376-.079.4857-1.2142.6193-1.6393-.3886-3.825-.9107-1.3113-.3279h-.1822v.1093l1.0929 1.0686 2.0035 1.8092 2.5075 2.3314.1275.5768-.3218.4554-.34-.0486-2.2039-1.6575-.85-.7468-1.9246-1.621h-.1275v.17l.4432.6496 2.3436 3.5214.1214 1.0807-.17.3521-.6071.2125-.6679-.1214-1.3721-1.9246L14.38 17.959l-1.1414-1.9428-.1397.079-.674 7.2552-.3156.3703-.7286.2793-.6071-.4614-.3218-.7468.3218-1.4753.3886-1.9246.3157-1.53.2853-1.9004.17-.6314-.0121-.0425-.1397.0182-1.4328 1.9672-2.1796 2.9446-1.7243 1.8456-.4128.164-.7164-.3704.0667-.6618.4008-.5889 2.386-3.0357 1.4389-1.882.929-1.0868-.0062-.1579h-.0546l-6.3385 4.1164-1.1293.1457-.4857-.4554.0608-.7467.2307-.2429 1.9064-1.3114Z'
---

<div class="agent-demo" x-data="agentDemo" aria-label="Example agent session using the seo CLI">
  <div class="agent-demo-titlebar">
    <span class="window-dots" aria-hidden="true"><span></span><span></span><span></span></span>
    <span class="window-title">SEO agent session</span>
    <span class="window-hint">local / example data</span>
  </div>
  <div class="agent-demo-feed">
    <noscript>
      <div class="demo-turn user">
        <span class="user-dot" aria-hidden="true"></span>
        <div class="demo-body">
          <p class="demo-text">What should I fix first on example.com?</p>
        </div>
      </div>
      <div class="demo-turn agent">
        <div class="demo-body">
          <p class="demo-text">
            seo report ran the main report and seo refresh-priorities ranked the
            follow-up work. Three fixes lead the queue, and each one is tied to
            pages that already earn impressions.
          </p>
        </div>
      </div>
    </noscript>
    <template x-for="a in indices" :key="a">
      <div class="demo-turn" :class="msg(a).role">
        <template x-if="msg(a).role === 'user'">
          <span class="user-dot" aria-hidden="true"></span>
        </template>
        <template x-if="msg(a).role === 'agent'">
          <svg class="claude-mark" viewBox="0 0 24 24" aria-label="Claude">
            <path d={claudePath}></path>
          </svg>
        </template>
        <div class="demo-body">
          <template x-if="msg(a).role === 'agent' && (msg(a).tools ?? []).length > 0">
            <div class="demo-toolrun">
              <template x-if="!toolDone(a)">
                <span class="thinking-dots" aria-hidden="true">
                  <span style="animation: braille-pulse 1.4s ease-in-out 0s infinite"></span>
                  <span style="animation: braille-pulse 1.1s ease-in-out 0.15s infinite"></span>
                  <span style="animation: braille-pulse 1.6s ease-in-out 0.3s infinite"></span>
                  <span style="animation: braille-pulse 1.3s ease-in-out 0.45s infinite"></span>
                  <span style="animation: braille-pulse 1.8s ease-in-out 0.6s infinite"></span>
                  <span style="animation: braille-pulse 1s ease-in-out 0s infinite"></span>
                  <span style="animation: braille-pulse 1.5s ease-in-out 0.15s infinite"></span>
                  <span style="animation: braille-pulse 1.2s ease-in-out 0.3s infinite"></span>
                  <span style="animation: braille-pulse 1.7s ease-in-out 0.45s infinite"></span>
                </span>
              </template>
              <template x-if="!toolDone(a)">
                <code x-text="activeTool(a)"></code>
              </template>
              <template x-if="toolDone(a)">
                <span x-text="toolSummary(a)"></span>
              </template>
            </div>
          </template>

          <template x-if="!running(a) && textFor(a)">
            <p class="demo-text">
              <span x-text="textFor(a)"></span>
              <span class="demo-caret" x-show="typingNow(a)" aria-hidden="true"></span>
            </p>
          </template>

          <template x-if="!running(a) && showExtras(a) && msg(a).chart">
            <div class="demo-chart" aria-hidden="true">
              <template x-for="(d, i) in msg(a).chart.data" :key="d.label">
                <div class="bar-col" :class="barOn(a, i) ? 'on' : ''">
                  <div class="bar" :style="{ height: barHeight(a, i) }"></div>
                  <span class="bar-label" x-text="d.label"></span>
                </div>
              </template>
            </div>
          </template>

          <template x-if="!running(a) && (msg(a).bullets ?? []).length > 0">
            <ul class="demo-bullets">
              <template x-for="(b, bi) in msg(a).bullets" :key="b">
                <li x-show="bulletVisible(a, bi)">
                  <span>
                    <span x-text="bulletText(a, bi)"></span>
                    <span class="demo-caret" x-show="bulletTyping(a, bi)" aria-hidden="true"></span>
                  </span>
                </li>
              </template>
            </ul>
          </template>

          <template x-if="!running(a) && showExtras(a) && msg(a).card">
            <div class="demo-card">
              <p class="card-title" x-text="msg(a).card.title"></p>
              <p class="card-body" :class="msg(a).card.mono ? 'mono' : ''" x-text="msg(a).card.body"></p>
            </div>
          </template>

          <template x-if="!running(a) && showExtras(a) && msg(a).action">
            <div class="demo-action">
              <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 10.5 8.5 15 16 6"></path></svg>
              <span x-text="msg(a).action"></span>
            </div>
          </template>
        </div>
      </div>
    </template>
  </div>
</div>

<script>
  import '@/scripts/agent-demo'
</script>
