---
type Props = {
  title: string
  description?: string
  align?: 'center' | 'left'
  class?: string
}

const { title, description, align = 'center', class: className } = Astro.props
const hasActions = Astro.slots.has('actions')
const centered = align === 'center'
---

<header class:list={['mb-10 space-y-4', centered && 'text-center', className]}>
  <h1 class="text-pretty text-3xl font-normal leading-tight tracking-tight sm:text-4xl">{title}</h1>
  {
    description ? (
      <p
        class:list={[
          'text-pretty font-sans text-lg leading-7 tracking-tight text-foreground-muted sm:text-xl sm:leading-8',
          centered && 'mx-auto max-w-2xl',
        ]}
      >
        {description}
      </p>
    ) : null
  }
  {
    hasActions ? (
      <div class:list={['flex items-center gap-3', centered && 'justify-center']}>
        <slot name="actions" />
      </div>
    ) : null
  }
</header>
