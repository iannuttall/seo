---
import { installCommands } from '@/lib/install'

const initial = installCommands[0]
---

<div class="install-picker" data-install-picker>
  <div class="install-tabs" role="tablist" aria-label="Install method">
    {installCommands.map((entry, index) => (
      <button
        type="button"
        role="tab"
        id={`install-tab-${entry.id}`}
        aria-controls="install-command"
        aria-selected={index === 0 ? 'true' : 'false'}
        data-install-option
        data-command={entry.command}
      >
        {entry.label}
      </button>
    ))}
  </div>
  <div id="install-command" role="tabpanel" aria-labelledby={`install-tab-${initial.id}`}>
    <button
      class="install-command"
      type="button"
      data-copy-button
      data-copy-value={initial.command}
      aria-label={`Copy ${initial.command}`}
    >
      <code><span aria-hidden="true">$ </span><span data-install-output>{initial.command}</span></code>
      <span class="copy-control">
        <svg viewBox="0 0 20 20" aria-hidden="true">
          <path d="M6 6V3h11v11h-3M3 6h11v11H3z"></path>
        </svg>
        <span data-copy-label>copy</span>
      </span>
    </button>
  </div>
</div>
