---
import DottedCard from '@/components/DottedCard.astro'
import FeatureShowcase from '@/components/FeatureShowcase.astro'
import InstallPicker from '@/components/InstallPicker.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import {
  Accordion,
  AccordionContent,
  AccordionItem,
  AccordionTrigger,
} from '@/components/ui/accordion'
import { reports } from '@/content/reports'
import {
  reportCollectionIds,
  reportCollections,
} from '@/content/reports/collections'
import { reportPath } from '@/content/reports/helpers'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { site } from '@/lib/site'

const catalogIds = reports.map((report) => report.id)
if (
  new Set(reportCollectionIds).size !== reportCollectionIds.length ||
  [...reportCollectionIds].sort().join('\n') !== [...catalogIds].sort().join('\n')
) {
  throw new Error('Home report groups do not match the live report catalog.')
}

const faqs = [
  {
    question: 'Does the SEO skill include an AI agent?',
    answer:
      'No. It gives Claude, ChatGPT, Codex, Cursor, and other agents better SEO context. The model still does the reasoning, writing, and implementation work, and the CLI provides the crawl data, Search Console data, GA4 data, and report evidence.',
  },
  {
    question: 'Why not build another SEO dashboard?',
    answer:
      'Dashboards are useful when you want to click around, but the CLI is built for the way agents work. They discover reports, run them, and read structured evidence without leaving your editor or terminal.',
  },
  {
    question: 'What does my agent actually get back?',
    answer:
      'It gets JSON or Markdown with the date range, units, caveats, evidence, recommendations, and useful next commands. That gives the model enough context to explain the problem and help fix it.',
  },
  {
    question: 'Why connect Search Console?',
    answer:
      'Search Console proves you can access the site and gives reports real search demand. That lets your agent find page-two queries, weak CTR, decaying pages, cannibalisation, and indexing candidates using your own data. The CLI requests read-only access.',
  },
  {
    question: 'Is GA4 required?',
    answer:
      'No. Crawls and Search Console reports work without GA4. Connect it when traffic, landing-page, engagement, or conversion context would change how you prioritise the work.',
  },
  {
    question: 'Does my site data leave my machine?',
    answer:
      'Reports, project profiles, tokens, crawls, and caches stay local. The CLI only sends the requests needed to fetch the site and call the Google APIs you connect.',
  },
  {
    question: 'Can it change my site?',
    answer:
      'The CLI does not publish changes by itself. It gives your agent the evidence it needs to edit code or content, draft a fix, or open a ticket inside the tools you already use.',
  },
  {
    question: 'Do I need MCP?',
    answer:
      'No. Use the CLI directly, import the package in TypeScript, or run it in CI. MCP is the easiest way to give a compatible agent the same local report engine.',
  },
  {
    question: 'Why one skill instead of a skill per report?',
    answer:
      'Fifty skill files would sit in your agent context window on every session, whether or not you are doing SEO work. This is one short skill that teaches your agent to discover the tools at runtime. The agent asks the CLI to describe a report only when it is about to run it, so it gets the full detail at the moment it matters and nothing before that.',
  },
  {
    question: 'Which report should I run first?',
    answer:
      'Run seo report after setup. It checks the evidence available for the project, explains skipped sections, ranks the first investigation queue, and points to focused follow-up reports.',
  },
  {
    question: 'How is this different from generic SEO advice?',
    answer:
      'Generic advice guesses from best practices, but your agent works from the site, crawl, queries, search demand, and analytics data in front of it. It can inspect the evidence behind each finding instead of trusting a generic score.',
  },
  {
    question: 'Who is the SEO skill for?',
    answer:
      'Developers, founders, SEO consultants, agencies, and technical teams who want their agents to work from clean SEO evidence instead of screenshots or copied dashboard rows.',
  },
]
---

<BaseLayout
  title="Open source SEO audit tool for AI agents"
  description={site.description}
  framed={false}
>
  <main data-agent-content="true">
    <section class="border-b-2 border-nav">
      <div class="hero-shell mx-auto w-full max-w-4xl px-8 md:px-12">
        <div class="hero-copy">
          <h1
            class="text-center text-pretty text-4xl font-normal leading-tight tracking-tight max-[420px]:text-[7.2vw] sm:text-5xl"
            data-glitch
            aria-label="The only SEO skill your agent needs"
          >
            <span class="block whitespace-nowrap" data-glitch-line aria-hidden="true">The only SEO skill</span>
            <span class="block whitespace-nowrap" data-glitch-line aria-hidden="true">your agent needs</span>
          </h1>
          <p class="text-center text-pretty font-sans text-xl leading-7 tracking-tight text-foreground-muted sm:text-2xl sm:leading-8">
            One SEO skill and {reports.length} audit tools for AI agents to fix
            issues, measure performance, and grow your organic and AI search
            visibility.
          </p>
        </div>
        <InstallPicker />
      </div>
    </section>

    <FeatureShowcase />

    <section class="mb-12 border-b-2 border-nav bg-panel text-panel-foreground">
      <div class="mx-auto w-full max-w-4xl px-8 md:px-12">
        <div class="px-6 py-12 sm:px-8">
          <div class="mb-10 space-y-4 text-center">
            <h2 class="text-pretty text-3xl font-normal leading-tight tracking-tight sm:text-4xl">
              Reports for a complete SEO audit
            </h2>
            <p class="mx-auto max-w-2xl text-pretty font-sans text-lg leading-7 tracking-tight text-panel-foreground/70 sm:text-xl sm:leading-8">
              {reports.length} reports and tools across crawl health, Search Console and GA4,
              opportunities, AI readiness, and monitoring.
            </p>
          </div>
          <div class="grid grid-cols-1 gap-x-10 gap-y-8 sm:auto-rows-fr sm:grid-cols-2">
            {
              reportCollections.map((group, index) => (
                <DottedCard inverted patternId={`report-group-${index}`}>
                  <span slot="label">{group.title}</span>
                  <ul class="flex flex-col gap-1.5 p-5 pb-8 font-sans text-sm">
                    {group.reports.map(([id, label]) => (
                      <li>
                        <a class="underline underline-offset-2 hover:decoration-dotted" href={reportPath(id)}>{label}</a>
                      </li>
                    ))}
                  </ul>
                </DottedCard>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section>
      <div class="mx-auto w-full max-w-4xl px-8 py-12 md:px-12">
        <SectionHeading
          eyebrow="Questions about the CLI, MCP, and your data"
          text="Give the best models better SEO evidence without replacing Claude, ChatGPT, Codex, Cursor, or the agent workflow you already use."
        />
        <DottedCard patternId="faq-card">
          <Accordion>
            {
              faqs.map((item) => (
                <AccordionItem value={item.question}>
                  <AccordionTrigger>{item.question}</AccordionTrigger>
                  <AccordionContent>{item.answer}</AccordionContent>
                </AccordionItem>
              ))
            }
          </Accordion>
        </DottedCard>
      </div>
    </section>
  </main>
  <script is:inline>
    ;(() => {
      const headline = document.querySelector('[data-glitch]')
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)')
      if (!headline || reducedMotion.matches) return

      const characters = []
      for (const line of headline.querySelectorAll('[data-glitch-line]')) {
        const source = line.textContent ?? ''
        line.textContent = ''

        for (const [wordIndex, word] of source.split(' ').entries()) {
          if (wordIndex > 0) line.append(' ')

          const wordSpan = document.createElement('span')
          wordSpan.style.display = 'inline-block'
          wordSpan.style.whiteSpace = 'nowrap'
          line.append(wordSpan)

          for (const character of word) {
            const span = document.createElement('span')
            span.textContent = character
            span.style.display = 'inline-block'
            span.style.width = '1ch'
            span.dataset.source = character
            wordSpan.append(span)
            characters.push(span)
          }
        }
      }

      const glyphs = '0123456789_<>/[]{}'
      const random = (minimum, range) => minimum + Math.random() * range

      const schedule = () => {
        window.setTimeout(() => {
          if (!document.hidden) {
            const available = [...characters]
            const count = 2 + Math.floor(Math.random() * 3)
            const simultaneous = Math.random() < 0.2
            let offset = random(0, 120)

            for (let index = 0; index < count; index += 1) {
              const position = Math.floor(Math.random() * available.length)
              const character = available.splice(position, 1)[0]
              if (!character) continue

              if (index > 0 && !simultaneous) {
                offset +=
                  Math.random() < 0.3 ? random(10, 35) : random(90, 220)
              }

              window.setTimeout(() => {
                character.textContent = glyphs[Math.floor(Math.random() * glyphs.length)]
                window.setTimeout(() => {
                  character.textContent = character.dataset.source ?? ''
                }, random(70, 130))
              }, offset)
            }
          }

          schedule()
        }, random(1800, 3800))
      }

      schedule()
    })()
  </script>
  <style>
    .hero-shell {
      display: flex;
      flex-direction: column;
      gap: clamp(2rem, 4vh, 4rem);
      padding-top: clamp(2.5rem, 5vh, 4.5rem);
      padding-bottom: clamp(4.5rem, 8vh, 7rem);
    }

    .hero-copy {
      display: flex;
      flex-direction: column;
      gap: clamp(1.5rem, 3vh, 2.5rem);
    }
  </style>
</BaseLayout>
