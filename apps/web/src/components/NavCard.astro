---
import DottedCard from '@/components/DottedCard.astro'
import PixelIcon from '@/components/icons/PixelIcon.astro'

type Props = {
  title: string
  description?: string
  href?: string
  class?: string
}

const { title, description, href, class: className } = Astro.props
const patternId = `nav-card-${(href ?? title).replace(/[^a-z0-9]+/gi, '-').toLowerCase()}`
const Tag = href ? 'a' : 'div'
---

<Tag href={href} class:list={['group block h-full', href && 'cursor-pointer', className]}>
  <DottedCard patternId={patternId}>
    <div class="flex h-full flex-col gap-3 p-5 pb-8">
      {description ? <p class="font-sans text-sm font-light text-foreground-muted">{description}</p> : null}
      <slot />
    </div>
    <span slot="label" class="inline-flex items-center gap-2 whitespace-nowrap">
      {title}
      <PixelIcon name="arrow-right" class="nav-card-arrow size-3.5 shrink-0" />
    </span>
  </DottedCard>
</Tag>
