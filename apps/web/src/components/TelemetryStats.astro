---
import DottedCard from '@/components/DottedCard.astro'
import PageHeader from '@/components/PageHeader.astro'
import { reports } from '@/content/reports'

const reportLabelsJson = JSON.stringify(
  Object.fromEntries(reports.map((report) => [report.id, report.name])),
)

const metrics = [
  ['installs', 'Recorded installs'],
  ['auditsStarted', 'Recorded audits'],
  ['auditsThisMonth', 'Audits run this month'],
  ['setupCompletions', 'Setup completions'],
  ['firstAuditConversionPercent', 'First audit event ratio'],
  ['auditsFailed', 'Failed audits'],
] as const
---

<div data-stats-root data-report-labels={reportLabelsJson} aria-busy="true">
  <PageHeader
    title="Anonymous usage stats"
    description="Aggregate event counts from installs that leave anonymous telemetry enabled. No user, machine, site, URL, report content, Google data, or location is attached to any event."
    align="left"
  >
    <p slot="actions" class="animate-pulse font-sans text-sm text-foreground-muted" data-stats-status data-stats-loading data-agent-markdown="exclude" aria-live="polite">
      Fetching current totals.
    </p>
    <p slot="actions" hidden data-agent-markdown="only">
      Agents can fetch current values as JSON with a GET request to
      https://seoskill.dev/api/stats.
    </p>
  </PageHeader>

  <section class="mb-14" aria-label="Usage totals" data-agent-markdown="exclude">
    <div class="grid items-stretch gap-5 sm:auto-rows-fr sm:grid-cols-2 lg:grid-cols-3">
      {
        metrics.map(([key, label]) => (
          <DottedCard patternId={`telemetry-stat-${key}`}>
            <article class="flex h-full min-h-32 flex-col justify-between gap-5 p-5 sm:p-6">
              <p class="font-sans text-sm text-foreground-muted">{label}</p>
              <p class="animate-pulse text-2xl sm:text-3xl" data-stat={key} data-stats-loading>
                {key === 'firstAuditConversionPercent' ? '0%' : '0'}
              </p>
            </article>
          </DottedCard>
        ))
      }
    </div>
  </section>

  <div class="mb-14 grid items-start gap-5 lg:grid-cols-2" data-agent-markdown="exclude">
    <section class="space-y-5" aria-labelledby="agent-installs-heading">
      <h2 id="agent-installs-heading" class="font-mono text-xl font-normal leading-tight">
        Install agent breakdown
      </h2>
      <div class="docs-prose">
        <div class="table-frame">
          <table class="min-w-0">
            <thead><tr><th>Agent</th><th class="text-right">Installs</th><th class="text-right">Share</th></tr></thead>
            <tbody class="animate-pulse" data-agent-table="installs" data-stats-loading><tr><td colspan="3">No recorded events</td></tr></tbody>
          </table>
        </div>
      </div>
    </section>
    <section class="space-y-5" aria-labelledby="agent-audits-heading">
      <h2 id="agent-audits-heading" class="font-mono text-xl font-normal leading-tight">
        Audit agent breakdown
      </h2>
      <div class="docs-prose">
        <div class="table-frame">
          <table class="min-w-0">
            <thead><tr><th>Agent</th><th class="text-right">Audits</th><th class="text-right">Share</th></tr></thead>
            <tbody class="animate-pulse" data-agent-table="audits" data-stats-loading><tr><td colspan="3">No recorded events</td></tr></tbody>
          </table>
        </div>
      </div>
    </section>
  </div>

  <section class="mb-14 space-y-5" aria-labelledby="retention-heading" data-agent-markdown="exclude">
    <div class="space-y-2">
      <h2 id="retention-heading" class="font-mono text-xl font-normal leading-tight">
        Day 7 retention by install week
      </h2>
      <p class="font-sans text-[0.9375rem] font-light leading-7">
        A retained install ran the tool at least seven days after its first run.
        Only complete weekly cohorts are shown.
      </p>
    </div>
    <div class="docs-prose">
      <div class="table-frame">
        <table>
          <thead><tr><th>Cohort</th><th class="text-right">Installs</th><th class="text-right">Active at day 7</th><th class="text-right">Retention</th></tr></thead>
          <tbody class="animate-pulse" data-retention-table data-stats-loading><tr><td colspan="4">No recorded events</td></tr></tbody>
        </table>
      </div>
    </div>
  </section>

  <div class="mb-14 grid items-stretch gap-5 lg:grid-cols-2" data-agent-markdown="exclude">
    <section class="flex h-full flex-col gap-5" aria-labelledby="popular-reports-heading">
      <h2 id="popular-reports-heading" class="font-mono text-xl font-normal leading-tight">
        Most run reports
      </h2>
      <DottedCard patternId="telemetry-popular-reports" class="h-full">
        <ol class="animate-pulse divide-y divide-border font-sans text-sm" data-report-list="popular" data-stats-loading><li class="p-4">No recorded events</li></ol>
      </DottedCard>
    </section>
    <section class="flex h-full flex-col gap-5" aria-labelledby="quiet-reports-heading">
      <h2 id="quiet-reports-heading" class="font-mono text-xl font-normal leading-tight">
        Least run reports
      </h2>
      <DottedCard patternId="telemetry-quiet-reports" class="h-full">
        <ol class="animate-pulse divide-y divide-border font-sans text-sm" data-report-list="quiet" data-stats-loading><li class="p-4">No recorded events</li></ol>
      </DottedCard>
    </section>
  </div>

  <section aria-labelledby="reading-stats">
    <DottedCard patternId="telemetry-reading-stats" inverted>
      <div class="space-y-5 p-5 sm:p-6">
        <h2 id="reading-stats" class="font-mono text-xl font-normal leading-tight">
          How to read these numbers
        </h2>
        <div class="space-y-4 font-sans text-sm font-light leading-6">
          <p>
            These are event totals, not people. One person can use several machines,
            clearing local state creates a new install, and disabled or CI runs do not
            appear. The first audit ratio divides first completed audit events by
            all recorded first run events. It is not an identity-linked funnel.
          </p>
          <p>
            The totals cover events recorded since anonymous collection began. Read
            the <a class="text-primary underline underline-offset-4 hover:decoration-dotted" href="/telemetry">full telemetry specification</a>
            {' '}or inspect the{' '}
            <a class="text-primary underline underline-offset-4 hover:decoration-dotted" href="/api/stats">aggregate JSON</a>.
          </p>
        </div>
      </div>
    </DottedCard>
  </section>
</div>

<script>
  const numberFormat = new Intl.NumberFormat('en-GB', {
    maximumFractionDigits: 0,
  })

  const text = (element: Element | null, value: string) => {
    if (element) element.textContent = value
  }

  const count = (value: unknown) =>
    typeof value === 'number' && Number.isFinite(value)
      ? numberFormat.format(value)
      : '0'

  const percent = (value: unknown) =>
    typeof value === 'number' && Number.isFinite(value)
      ? `${value.toFixed(1).replace('.0', '')}%`
      : '0%'

  const cell = (value: string, align = 'left') => {
    const element = document.createElement('td')
    element.className = align === 'right' ? 'text-right' : 'text-left'
    element.textContent = value
    return element
  }

  const emptyRow = (columns: number) => {
    const row = document.createElement('tr')
    const value = cell('No recorded events')
    value.colSpan = columns
    row.append(value)
    return row
  }

  const renderAgents = (
    table: Element | null,
    rows: Array<{ agent: string; count: number; percent: number }>,
  ) => {
    if (!(table instanceof HTMLElement)) return
    table.replaceChildren()
    if (rows.length === 0) {
      table.append(emptyRow(3))
      return
    }
    for (const item of rows) {
      const row = document.createElement('tr')
      row.append(
        cell(item.agent),
        cell(count(item.count), 'right'),
        cell(percent(item.percent), 'right'),
      )
      table.append(row)
    }
  }

  const renderRetention = (
    table: Element | null,
    rows: Array<{
      cohort: string
      installs: number
      retained: number
      percent: number | null
      complete: boolean
    }>,
  ) => {
    if (!(table instanceof HTMLElement)) return
    table.replaceChildren()
    const completeRows = rows.filter((row) => row.complete).slice(0, 12)
    if (completeRows.length === 0) {
      table.append(emptyRow(4))
      return
    }
    for (const item of completeRows) {
      const row = document.createElement('tr')
      row.append(
        cell(item.cohort),
        cell(count(item.installs), 'right'),
        cell(count(item.retained), 'right'),
        cell(percent(item.percent), 'right'),
      )
      table.append(row)
    }
  }

  const reportPath = (report: string) =>
    `/docs/reports/${report === 'index-coverage-plan' ? 'index-plan' : report}`

  const reportLabels = (() => {
    const value = document
      .querySelector('[data-stats-root]')
      ?.getAttribute('data-report-labels')
    if (!value) return {} as Record<string, string>
    try {
      return JSON.parse(value) as Record<string, string>
    } catch {
      return {} as Record<string, string>
    }
  })()

  const reportLabel = (report: string) =>
    reportLabels[report] ??
    report
      .split('-')
      .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
      .join(' ')

  const renderReports = (
    list: Element | null,
    rows: Array<{ report: string; count: number }>,
  ) => {
    if (!(list instanceof HTMLElement)) return
    list.replaceChildren()
    if (rows.length === 0) {
      const row = document.createElement('li')
      row.className = 'p-4'
      row.textContent = 'No recorded events'
      list.append(row)
      return
    }
    for (const item of rows) {
      const row = document.createElement('li')
      row.className = 'flex items-center justify-between gap-4 p-4'
      const link = document.createElement('a')
      link.className = 'text-primary underline underline-offset-2 hover:decoration-dotted'
      link.href = reportPath(item.report)
      link.textContent = reportLabel(item.report)
      const value = document.createElement('span')
      value.textContent = count(item.count)
      row.append(link, value)
      list.append(row)
    }
  }

  const loadStats = async () => {
    const status = document.querySelector('[data-stats-status]')
    try {
      const response = await fetch('/api/stats', {
        headers: { accept: 'application/json' },
      })
      if (!response.ok) throw new Error('Stats request failed')
      const stats = await response.json()
      const totals = stats.totals ?? {}
      for (const key of [
        'installs',
        'auditsStarted',
        'auditsThisMonth',
        'setupCompletions',
        'auditsFailed',
      ]) {
        text(document.querySelector(`[data-stat="${key}"]`), count(totals[key]))
      }
      text(
        document.querySelector('[data-stat="firstAuditConversionPercent"]'),
        percent(totals.firstAuditConversionPercent),
      )
      renderAgents(
        document.querySelector('[data-agent-table="installs"]'),
        stats.agents?.installs ?? [],
      )
      renderAgents(
        document.querySelector('[data-agent-table="audits"]'),
        stats.agents?.audits ?? [],
      )
      renderRetention(
        document.querySelector('[data-retention-table]'),
        stats.retentionD7 ?? [],
      )
      const reports = Array.isArray(stats.reports) ? stats.reports : []
      renderReports(
        document.querySelector('[data-report-list="popular"]'),
        reports
          .filter((item: { count: number }) => item.count > 0)
          .slice(0, 10),
      )
      renderReports(
        document.querySelector('[data-report-list="quiet"]'),
        [...reports]
          .filter((item: { count: number }) => item.count > 0)
          .sort((a, b) => a.count - b.count || a.report.localeCompare(b.report))
          .slice(0, 10),
      )
      const generated = new Date(stats.generatedAt)
      text(
        status,
        Number.isNaN(generated.getTime())
          ? 'Aggregate counts loaded.'
          : `Updated ${generated.toLocaleString('en-GB', { dateStyle: 'medium', timeStyle: 'short', timeZone: 'UTC' })} UTC.`,
      )
    } catch {
      text(status, 'Live aggregate counts are temporarily unavailable.')
    } finally {
      document.querySelector('[data-stats-root]')?.setAttribute('aria-busy', 'false')
      document.querySelectorAll('[data-stats-loading]').forEach((item) => {
        item.classList.remove('animate-pulse')
        item.removeAttribute('data-stats-loading')
      })
    }
  }

  void loadStats()
</script>
