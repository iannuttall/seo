---
import DottedCard from '@/components/DottedCard.astro'
import NavCard from '@/components/NavCard.astro'

const measurements = [
  ['Answers', 'The retained answer for each exact prompt, surface, chosen model, model the provider actually ran, settings, and time.'],
  ['Named targets', 'Whether supplied brand aliases appeared in that answer sample, kept separate from citations.'],
  ['Citations', 'Which pages and domains appeared in returned citation metadata, including citations that do not name the target.'],
  ['Prompt set coverage', 'How many completed observations in the fixed set included the target or one of its domains.'],
  ['Supporting searches', 'Extra searches the provider reports using to form an answer. The structured result calls these fan-out queries.'],
  ['Like-for-like change', 'Which answers, citation domains, or named targets changed between complete observations with the same configuration.'],
] as const

const requirements = [
  'A local DataForSEO connection with spend and request limits set.',
  'One to five fixed prompts, with stable ids and optional groups.',
  'One to four exact current model names from ChatGPT, Claude, Gemini, or Perplexity.',
  'Your target aliases and domains, plus no more than five named competitors.',
  'An optional Search Console property when first-party query context would help.',
] as const
---

<div class="space-y-14" data-prose-ignore>
  <DottedCard patternId="ai-visibility-status" inverted>
    <div class="space-y-5 p-5 sm:p-7">
      <div class="flex flex-wrap items-center gap-3">
        <span class="border-2 border-primary bg-primary px-2 py-1 font-mono text-xs text-primary-foreground selection:bg-primary-foreground selection:text-primary">
          Available now
        </span>
        <h2 class="font-mono text-xl font-normal leading-tight text-panel-foreground">
          Record fixed AI prompt observations locally
        </h2>
      </div>
      <div class="max-w-3xl space-y-4 font-sans text-sm font-light leading-7 text-panel-foreground/80 sm:text-[0.9375rem]">
        <p>
          Run a small fixed set of prompts against explicit current models in ChatGPT,
          Claude, Gemini, or Perplexity. Each observation keeps the answer, citations,
          model the provider actually ran, token use, cache state, provider task id, and
          exact returned cost.
        </p>
        <p>
          The report stores bounded history on this computer and compares only compatible
          observations. It does not turn a handful of generated answers into a universal
          visibility score or assistant ranking.
        </p>
      </div>
    </div>
  </DottedCard>

  <section aria-labelledby="visibility-measurements" class="space-y-5">
    <div class="space-y-2">
      <h2 id="visibility-measurements" class="font-mono text-xl font-normal leading-tight">
        What the report records
      </h2>
      <p class="max-w-3xl font-sans text-[0.9375rem] font-light leading-7 text-foreground-muted">
        The evidence stays attached to every summary. Read the answer, model, settings,
        source coverage, and collection time before interpreting a mention or change.
      </p>
    </div>

    <DottedCard patternId="ai-visibility-measurements">
      <div class="overflow-x-auto">
        <table class="w-full min-w-[42rem] border-collapse text-left">
          <caption class="sr-only">Evidence recorded for fixed AI prompt observations</caption>
          <thead class="bg-report-header text-report-header-foreground">
            <tr>
              <th class="w-48 border-b-2 border-nav px-5 py-3 font-mono text-xs font-normal sm:text-sm">
                Measurement
              </th>
              <th class="border-b-2 border-nav px-5 py-3 font-mono text-xs font-normal sm:text-sm">
                What it tells you
              </th>
            </tr>
          </thead>
          <tbody>
            {
              measurements.map(([label, detail]) => (
                <tr>
                  <th class="px-5 py-4 align-top font-sans text-sm font-medium">{label}</th>
                  <td class="px-5 py-4 font-sans text-sm font-light leading-6 text-foreground-muted">
                    {detail}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </DottedCard>

    <p class="max-w-3xl font-sans text-[0.9375rem] font-light leading-7 text-foreground-muted">
      Cached observations, model changes, partial answers, and truncated answers stay
      non-comparable. Missing, unavailable, and not observed remain different states.
    </p>
  </section>

  <section aria-labelledby="visibility-now" class="space-y-5">
    <div class="space-y-2">
      <h2 id="visibility-now" class="font-mono text-xl font-normal leading-tight">
        Use the right evidence for the question
      </h2>
      <p class="max-w-3xl font-sans text-[0.9375rem] font-light leading-7 text-foreground-muted">
        Live answers, indexed mention research, technical eligibility, and recorded visits
        answer different questions. Keep them separate until a decision needs them together.
      </p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2">
      <NavCard
        title="AI prompt observation report"
        description="Record current answers, mentions, citations, supporting searches, like-for-like changes, and exact costs for a small fixed set of prompts."
        href="/docs/reports/ai-prompt-observations"
      />
      <NavCard
        title="AI mention research report"
        description="Research provider-indexed mentions, cited domains, and bounded question samples for one surface and market."
        href="/docs/reports/ai-mention-research"
      />
      <NavCard
        title="AI search readiness audit"
        description="Check crawl access, indexability, snippet controls, page structure, and optional agent resources."
        href="/docs/reports/ai-readiness"
      />
      <NavCard
        title="Google AI search readiness audit"
        description="Check the technical controls Google documents for AI search eligibility."
        href="/docs/reports/geo-gaps"
      />
      <NavCard
        title="AI referral traffic report"
        description="Find visits from known AI assistants that reached the site and were recorded by Google Analytics."
        href="/docs/reports/ai-referrals"
      />
      <NavCard
        title="SEO query to AI prompt report"
        description="Turn real search queries into a stable prompt set for an external tracking provider."
        href="/docs/reports/seo-to-ai-query"
      />
    </div>

    <p class="max-w-3xl font-sans text-[0.9375rem] font-light leading-7 text-foreground-muted">
      A crawl restriction can affect eligibility. A live answer is one generated sample. A
      provider-indexed mention is bounded by that dataset. A Google Analytics referral proves
      that one recorded visit reached the site. None can replace the others.
    </p>
  </section>

  <section aria-labelledby="visibility-inputs" class="space-y-5">
    <div class="space-y-2">
      <h2 id="visibility-inputs" class="font-mono text-xl font-normal leading-tight">
        Run a small fixed set of prompts
      </h2>
      <p class="max-w-3xl font-sans text-[0.9375rem] font-light leading-7 text-foreground-muted">
        The report accepts no more than five prompts and four models, for a maximum of 20
        paid live requests. Start smaller and add only prompts that can change a decision.
      </p>
    </div>

    <DottedCard patternId="ai-visibility-inputs">
      <ol class="divide-y divide-border">
        {
          requirements.map((item, index) => (
            <li class="grid items-start gap-2 px-5 py-4 sm:grid-cols-[4rem_1fr] sm:gap-6">
              <span class="font-mono text-xs leading-6 text-foreground-muted">
                {String(index + 1).padStart(2, '0')}
              </span>
              <span class="font-sans text-sm font-light leading-6 text-foreground-muted">
                {item}
              </span>
            </li>
          ))
        }
      </ol>
    </DottedCard>

    <DottedCard patternId="ai-visibility-providers" inverted>
      <div class="space-y-4 p-5 sm:p-6">
        <h3 class="font-mono text-base font-normal leading-tight text-panel-foreground">
          Provider and model rules
        </h3>
        <div class="max-w-3xl space-y-4 font-sans text-sm font-light leading-7 text-panel-foreground/80">
          <p>
            DataForSEO supplies live AI responses now. The report contract is provider
            neutral, so another provider can implement the same capability later without
            changing how the report is read.
          </p>
          <p>
            Model names must match the provider's free current catalog. An invalid or stale
            name fails before a paid request and lists current choices. The base-price
            estimate stays separate from the exact task cost returned after completion.
          </p>
        </div>
      </div>
    </DottedCard>
  </section>

  <section aria-labelledby="visibility-limits">
    <DottedCard patternId="ai-visibility-limits" inverted>
      <div class="space-y-5 p-5 sm:p-6">
        <h2 id="visibility-limits" class="font-mono text-xl font-normal leading-tight text-panel-foreground">
          What AI visibility data still cannot prove
        </h2>
        <div class="max-w-3xl space-y-4 font-sans text-sm font-light leading-7 text-panel-foreground/80 sm:text-[0.9375rem]">
          <p>
            AI answers can vary on another request. A fixed prompt set gives you a repeatable
            sample across the prompts, models, market labels, settings, and dates you choose.
            A missing mention only means the retained answer did not contain a supplied alias
            or domain. It does not prove the target never appeared elsewhere.
          </p>
          <p>
            Citations need review. A returned URL can be irrelevant or attached to the wrong
            claim. Supporting-search themes and Search Console word matches are research
            leads, not proof of demand or permission to build a programmatic template.
          </p>
        </div>
      </div>
    </DottedCard>
  </section>
</div>
