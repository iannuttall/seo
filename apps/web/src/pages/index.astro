---
import HeroPanel from '@/components/HeroPanel.astro'
import InstallPicker from '@/components/InstallPicker.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import {
  Accordion,
  AccordionContent,
  AccordionItem,
  AccordionTrigger,
} from '@/components/ui/accordion'
import { reports } from '@/content/reports'
import {
  reportCollectionIds,
  reportCollections,
} from '@/content/reports/collections'
import { reportPath } from '@/content/reports/helpers'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { site } from '@/lib/site'

const catalogIds = reports.map((report) => report.id)
if (
  new Set(reportCollectionIds).size !== reportCollectionIds.length ||
  [...reportCollectionIds].sort().join('\n') !== [...catalogIds].sort().join('\n')
) {
  throw new Error('Home report groups do not match the live report catalog.')
}

const faqs = [
  {
    question: 'Does the SEO CLI include an AI agent?',
    answer:
      'No. It gives Claude, ChatGPT, Codex, Cursor, and other agents better SEO context. The model still does the reasoning, writing, and implementation work, and the CLI provides the crawl data, Search Console data, GA4 data, and report evidence.',
  },
  {
    question: 'Why not build another SEO dashboard?',
    answer:
      'Dashboards are useful when you want to click around, but the CLI is built for the way agents work. They discover reports, run them, and read structured evidence without leaving your editor or terminal.',
  },
  {
    question: 'What does my agent actually get back?',
    answer:
      'It gets JSON or Markdown with the date range, units, caveats, evidence, recommendations, and useful next commands. That gives the model enough context to explain the problem and help fix it.',
  },
  {
    question: 'Why connect Search Console?',
    answer:
      'Search Console proves you can access the site and gives reports real search demand. That lets your agent find page-two queries, weak CTR, decaying pages, cannibalisation, and indexing candidates using your own data. The CLI requests read-only access.',
  },
  {
    question: 'Is GA4 required?',
    answer:
      'No. Crawls and Search Console reports work without GA4. Connect it when traffic, landing-page, engagement, or conversion context would change how you prioritise the work.',
  },
  {
    question: 'Does my site data leave my machine?',
    answer:
      'Reports, project profiles, tokens, crawls, and caches stay local. The CLI only sends the requests needed to fetch the site and call the Google APIs you connect.',
  },
  {
    question: 'Can it change my site?',
    answer:
      'The CLI does not publish changes by itself. It gives your agent the evidence it needs to edit code or content, draft a fix, or open a ticket inside the tools you already use.',
  },
  {
    question: 'Do I need MCP?',
    answer:
      'No. Use the CLI directly, import the package in TypeScript, or run it in CI. MCP is the easiest way to give a compatible agent the same local report engine.',
  },
  {
    question: 'Why install both the CLI and the skills?',
    answer:
      'The CLI does the work. The skills teach an agent which report to choose, how to run it, what the result means, and which follow-up is worth the context. Agents work best with both.',
  },
  {
    question: 'Which report should I run first?',
    answer:
      'Run seo report after setup. It checks the evidence available for the project, explains skipped sections, ranks the first investigation queue, and points to focused follow-up reports.',
  },
  {
    question: 'How is this different from generic SEO advice?',
    answer:
      'Generic advice guesses from best practices, but your agent works from the site, crawl, queries, search demand, and analytics data in front of it. It can inspect the evidence behind each finding instead of trusting a generic score.',
  },
  {
    question: 'Who is the SEO CLI for?',
    answer:
      'Developers, founders, SEO consultants, agencies, and technical teams who want their agents to work from clean SEO evidence instead of screenshots or copied dashboard rows.',
  },
]
---

<BaseLayout
  title="Open source SEO audit tool for AI agents"
  description={site.description}
  framed={false}
>
  <main data-agent-content="true">
    <section class="flex flex-col border-b border-border bg-background pt-4 text-foreground">
      <div class="site-frame">
        <div class="flex flex-col gap-8 pt-16 sm:pt-24">
          <div class="flex max-w-2xl flex-col gap-4">
            <h1 class="text-pretty text-3xl font-medium -tracking-[0.5px] xl:text-4xl xl:-tracking-[0.7px]">
              Turn your agents into an SEO team that grows your organic and AI search visibility.
            </h1>
            <p class="text-pretty text-2xl/8 font-medium -tracking-[0.2px] text-foreground-muted xl:text-3xl/10 xl:-tracking-[0.4px]">
              Your agents crawl a site, read your Search Console and GA4 data, and run {reports.length} evidence-backed
              reports, all on your machine and inside the tools you already use.
            </p>
          </div>
          <InstallPicker />
        </div>
      </div>
    </section>

    <div class="space-y-24 py-24">
      <section class="site-frame grid grid-cols-1 gap-2 sm:grid-cols-2">
        <div class="rounded-lg bg-muted p-8">
          <h2 class="text-lg font-semibold">Your agent audits your site without you.</h2>
          <p class="mt-2 text-base leading-7 text-foreground-muted">
            It crawls the site, finds the technical SEO and AI-readiness issues, and hands back
            specific fixes. You stay in your editor while it does the busywork.
          </p>
        </div>
        <div class="rounded-lg bg-muted p-8">
          <h2 class="text-lg font-semibold">Data other tools keep behind a dashboard.</h2>
          <p class="mt-2 text-base leading-7 text-foreground-muted">
            Give your agent owner-verified Search Console and GA4 data on your machine,
            joined to crawl findings, so it sees what is actually losing visibility.
          </p>
        </div>
        <div class="rounded-lg bg-muted p-8">
          <h2 class="text-lg font-semibold">It lives in your CLI and MCP, where your agents already work.</h2>
          <p class="mt-2 text-base leading-7 text-foreground-muted">
            Run an audit from a script, an agent, your terminal, or CI and read the results back as
            structured JSON or Markdown.
          </p>
        </div>
        <div class="rounded-lg bg-muted p-8">
          <h2 class="text-lg font-semibold">Your search visibility grows while you ship.</h2>
          <p class="mt-2 text-base leading-7 text-foreground-muted">
            Your agent fixes issues, tracks new and resolved ones build over build, and measures the
            impact across organic and AI search.
          </p>
        </div>
      </section>

      <section class="site-frame">
        <SectionHeading
          eyebrow="See your agent in the loop"
          text="It reads your crawl findings and Search Console data, finds what is hurting visibility, then drafts the fix in your stack."
        />
        <HeroPanel />
      </section>

      <section class="site-frame">
        <SectionHeading
          eyebrow="Reports for a complete SEO audit"
          text={`${reports.length} reports and tools across crawl health, Search Console and GA4, opportunities, AI readiness, and monitoring.`}
        />
        <div class="grid grid-cols-1 gap-x-10 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
          {
            reportCollections.map((group) => (
              <div>
                <h3 class="text-lg font-medium text-foreground">{group.title}</h3>
                <ul class="mt-3 flex flex-col gap-1.5 text-base text-foreground-muted">
                  {group.reports.map(([id, label]) => (
                    <li>
                      <a class="body-link" href={reportPath(id)}>
                        {label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </section>

      <section class="site-frame">
        <div class="border-t border-border pt-12">
          <div class="max-w-2xl">
            <h2 class="text-pretty text-2xl font-medium -tracking-[0.4px] text-foreground xl:text-3xl xl:-tracking-[0.6px]">
              Questions people ask before giving an agent SEO evidence
            </h2>
            <p class="mt-4 text-pretty text-xl/7 font-medium -tracking-[0.15px] text-foreground-muted xl:text-2xl/8 xl:-tracking-[0.3px]">
              Give the best models better SEO evidence without replacing Claude, ChatGPT, Codex,
              Cursor, or the agent workflow you already use.
            </p>
          </div>

          <Accordion class="mt-6 space-y-2">
            {
              faqs.map((item) => (
                <AccordionItem value={item.question}>
                  <AccordionTrigger>{item.question}</AccordionTrigger>
                  <AccordionContent>{item.answer}</AccordionContent>
                </AccordionItem>
              ))
            }
          </Accordion>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
