---
import type { CollectionEntry } from 'astro:content'
import { getCollection, render } from 'astro:content'
import PageHeader from '@/components/PageHeader.astro'
import { docsMdxComponents } from '@/components/docs/mdx'
import { docsNavFor } from '@/content/docs-nav'
import BaseLayout from '@/layouts/BaseLayout.astro'

export async function getStaticPaths() {
  const docs = await getCollection('docs')

  return docs.map((entry) => ({
    params: { slug: entry.id === 'index' ? undefined : entry.id },
    props: { entry },
  }))
}

type Props = { entry: CollectionEntry<'docs'> }

const { entry } = Astro.props
const { Content } = await render(entry)
const path = entry.id === 'index' ? '/docs' : `/docs/${entry.id}`
const nav = docsNavFor(path)
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  canonicalPath={path}
>
  <main>
      {nav ? (
        <nav aria-label="Breadcrumb" class="mb-6 text-sm text-foreground-muted">
          <ol class="flex flex-wrap items-center gap-1.5">
            {nav.breadcrumbs.map((crumb, index) => (
              <li class="flex items-center gap-1.5">
                {crumb.href ? (
                  <a
                    class="underline decoration-border underline-offset-4 transition-colors hover:decoration-foreground"
                    href={crumb.href}
                  >
                    {crumb.label}
                  </a>
                ) : (
                  <span class="text-foreground">{crumb.label}</span>
                )}
                {index < nav.breadcrumbs.length - 1 ? (
                  <span aria-hidden="true" class="text-border">/</span>
                ) : null}
              </li>
            ))}
          </ol>
        </nav>
      ) : null}

      <PageHeader
        title={entry.data.heading ?? entry.data.title}
        description={entry.data.lead ?? entry.data.description}
        bordered={false}
      />

      <div class="docs-prose">
        <Content components={docsMdxComponents} />
      </div>

      {nav && (nav.prev || nav.next) ? (
        <nav
          aria-label="Docs pages"
          class="mt-16 flex items-stretch justify-between gap-4 pt-6"
        >
          {nav.prev ? (
            <a href={nav.prev.path} class="group flex flex-col gap-1 no-underline">
              <span class="text-sm text-foreground-muted">Previous</span>
              <span class="font-medium text-foreground underline decoration-border underline-offset-4 transition-colors group-hover:decoration-foreground">
                {nav.prev.label}
              </span>
            </a>
          ) : (
            <span />
          )}
          {nav.next ? (
            <a href={nav.next.path} class="group flex flex-col items-end gap-1 text-right no-underline">
              <span class="text-sm text-foreground-muted">Next</span>
              <span class="font-medium text-foreground underline decoration-border underline-offset-4 transition-colors group-hover:decoration-foreground">
                {nav.next.label}
              </span>
            </a>
          ) : (
            <span />
          )}
        </nav>
      ) : null}
  </main>
</BaseLayout>
